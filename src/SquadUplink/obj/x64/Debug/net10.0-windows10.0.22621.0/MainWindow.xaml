<Window x:ConnectionId='1'
    x:Class="SquadUplink.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink"
    xmlns:views="using:SquadUplink.Views"
    Title="Squad Uplink">

    <Grid>
        <Grid.KeyboardAccelerators>
            <!-- Ctrl+Tab: Next session -->
            <KeyboardAccelerator x:ConnectionId='2' Key="Tab" Modifiers="Control"
                                                               />
            <!-- Ctrl+Shift+Tab: Previous session -->
            <KeyboardAccelerator x:ConnectionId='3' Key="Tab" Modifiers="Control,Shift"
                                                                   />
            <!-- Ctrl+1..9: Jump to session by index -->
            <KeyboardAccelerator x:ConnectionId='4' Key="Number1" Modifiers="Control"
                                                                 />
            <KeyboardAccelerator x:ConnectionId='5' Key="Number2" Modifiers="Control"
                                                                 />
            <KeyboardAccelerator x:ConnectionId='6' Key="Number3" Modifiers="Control"
                                                                 />
            <KeyboardAccelerator x:ConnectionId='7' Key="Number4" Modifiers="Control"
                                                                 />
            <KeyboardAccelerator x:ConnectionId='8' Key="Number5" Modifiers="Control"
                                                                 />
            <KeyboardAccelerator x:ConnectionId='9' Key="Number6" Modifiers="Control"
                                                                 />
            <KeyboardAccelerator x:ConnectionId='10' Key="Number7" Modifiers="Control"
                                                                 />
            <KeyboardAccelerator x:ConnectionId='11' Key="Number8" Modifiers="Control"
                                                                 />
            <KeyboardAccelerator x:ConnectionId='12' Key="Number9" Modifiers="Control"
                                                                 />
            <!-- Ctrl+N: Launch new session -->
            <KeyboardAccelerator x:ConnectionId='13' Key="N" Modifiers="Control"
                                                                    />
            <!-- Ctrl+W: Close current session -->
            <KeyboardAccelerator x:ConnectionId='14' Key="W" Modifiers="Control"
                                                                       />
            <!-- F11: Toggle focused mode -->
            <KeyboardAccelerator x:ConnectionId='15' Key="F11"
                                                                     />
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:ConnectionId='16' x:Name="AppTitleBar" Grid.Row="0" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="18"
                       Foreground="{StaticResource SquadAccentGreenBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Grid.Column="1" Text="Squad Uplink"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       FontWeight="SemiBold" FontSize="13"
                       VerticalAlignment="Center" />
            <InfoBadge x:ConnectionId='22' Grid.Column="2" x:Name="SessionCountBadge"
                                                                 
                       Margin="8,0,0,0" VerticalAlignment="Center"
                       Style="{ThemeResource AttentionIconInfoBadgeStyle}" />
            <TextBlock x:ConnectionId='23' Grid.Column="4" x:Name="StatusText"
                                                                 
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Navigation + Content -->
        <NavigationView x:ConnectionId='17'
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            PaneDisplayMode="LeftCompact"
                                                       
            IsSettingsVisible="True"
            IsPaneToggleButtonVisible="True"
            OpenPaneLength="200">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sessions" Tag="Sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF0E2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:ConnectionId='18' x:Name="FooterStatusItem" SelectsOnInvoked="False" IsEnabled="False">
                    <NavigationViewItem.Icon>
                        <FontIcon x:ConnectionId='19' x:Name="FooterStatusIcon" Glyph="&#xE895;"
                                  Foreground="{StaticResource SquadAccentGreenBrush}" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock x:ConnectionId='20' x:Name="FooterStatusText" Text="Scanning..."
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:ConnectionId='21' x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>

