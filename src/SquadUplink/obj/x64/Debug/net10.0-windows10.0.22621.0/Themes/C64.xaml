<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Commodore 64 — Blue/lavender PETSCII-inspired theme            -->
    <!-- Background: #4040E0  Text: #A0A0FF  Accent: #FFFFFF            -->
    <!-- Border: #7070FF                                                -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="C64Background">#4040E0</Color>
    <Color x:Key="C64Text">#A0A0FF</Color>
    <Color x:Key="C64Accent">#FFFFFF</Color>
    <Color x:Key="C64Border">#7070FF</Color>
    <Color x:Key="C64Surface">#3535C0</Color>
    <Color x:Key="C64DimText">#6060CC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SquadAccentGreenBrush" Color="{StaticResource C64Accent}" />
    <SolidColorBrush x:Key="SquadAccentBlueBrush" Color="{StaticResource C64Text}" />
    <SolidColorBrush x:Key="SquadWarningYellowBrush" Color="#E0E040" />
    <SolidColorBrush x:Key="SquadErrorRedBrush" Color="#FF4040" />
    <SolidColorBrush x:Key="SquadNeutralGrayBrush" Color="{StaticResource C64DimText}" />

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource C64Background}" />

    <!-- Session Card — PETSCII-style border -->
    <Style x:Key="SessionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource C64Surface}" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource C64Border}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style x:Key="LaunchCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource C64DimText}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style x:Key="CockpitPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource C64Surface}" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource C64Border}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Typography — C64-style -->
    <Style x:Key="StatCounterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource C64Accent}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource C64DimText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource C64Accent}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource C64Text}" />
    </Style>

    <!-- Gauge -->
    <Style x:Key="GaugeRingStyle" TargetType="ProgressRing">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="IsIndeterminate" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource C64Accent}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

</ResourceDictionary>

