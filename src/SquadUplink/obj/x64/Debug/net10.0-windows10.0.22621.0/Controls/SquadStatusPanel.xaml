<UserControl x:ConnectionId='1'
    x:Class="SquadUplink.Controls.SquadStatusPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Controls"
    xmlns:models="using:SquadUplink.Models">

    <Border Style="{StaticResource CockpitPanelStyle}">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- No Selection State -->
            <StackPanel x:ConnectionId='2' x:Name="NoSelectionPanel" Grid.Row="0" Grid.RowSpan="4"
                                                                             
                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8FB;" FontSize="24"
                          Foreground="{ThemeResource TextFillColorDisabledBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Select a squad to view details"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" FontSize="12" />
            </StackPanel>

            <!-- Squad Header -->
            <StackPanel x:ConnectionId='3' Grid.Row="0" Spacing="4"
                                                                       >
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE716;" FontSize="18"
                              Foreground="{StaticResource SquadAccentGreenBrush}" />
                    <TextBlock x:ConnectionId='18'                                      
                               FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE774;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='17'                                          
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE77B;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='16'                                             
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Current Focus Callout -->
            <Border x:ConnectionId='4' Grid.Row="1"
                                                                   
                    Background="{StaticResource SquadAccentGreenBrush}"
                    Opacity="0.15" CornerRadius="6" Padding="12,8">
                <Grid>
                    <Border Background="{StaticResource SquadAccentGreenBrush}"
                            Opacity="0.85" CornerRadius="6" Padding="12,8"
                            Margin="-12,-8">
                    </Border>
                    <StackPanel Spacing="4">
                        <TextBlock Text="CURRENT FOCUS" FontSize="10"
                                   CharacterSpacing="80" FontWeight="SemiBold"
                                   Foreground="White" Opacity="0.8" />
                        <TextBlock x:ConnectionId='15'                                              
                                   FontSize="13" Foreground="White"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Decisions Summary -->
            <StackPanel x:ConnectionId='5' Grid.Row="2" Spacing="4"
                                                                       >
                <TextBlock Text="RECENT DECISIONS" FontSize="10"
                           CharacterSpacing="80"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:ConnectionId='14'                                              
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           MaxHeight="60" />
            </StackPanel>

            <!-- Member Cards -->
            <ScrollViewer x:ConnectionId='6' Grid.Row="3"
                                                                         
                          VerticalScrollBarVisibility="Auto">
                <ItemsRepeater x:ConnectionId='7' x:Name="MemberList"
                                                                              >
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate                                  >
                            <Border x:ConnectionId='9' Margin="0,2" Padding="8,6" CornerRadius="4"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:ConnectionId='10' Grid.Column="0"                                   
                                               FontSize="16" VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock x:ConnectionId='12'                                          
                                                   FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock x:ConnectionId='13'                                    FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                        <TextBlock x:ConnectionId='11'                                          FontSize="10" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>

