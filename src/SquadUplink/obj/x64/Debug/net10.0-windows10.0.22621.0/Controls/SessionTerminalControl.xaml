<UserControl
    x:Class="SquadUplink.Controls.SessionTerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SquadUplink.Converters">

    <UserControl.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrush" />
        <converters:StatusToTextConverter x:Key="StatusToText" />
    </UserControl.Resources>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Terminal area -->
        <Border Grid.Row="0" CornerRadius="6,6,0,0" BorderThickness="1,1,1,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid>
                <WebView2 x:ConnectionId='6' x:Name="TerminalWebView"
                          Source="ms-appx-web:///wwwroot/terminal.html" />

                <!-- Placeholder when no session is bound -->
                <StackPanel x:ConnectionId='7' x:Name="PlaceholderPanel"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="8" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE756;" FontSize="32"
                              Foreground="{ThemeResource TextFillColorDisabledBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No session attached"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Mini status bar -->
        <Border Grid.Row="1" CornerRadius="0,0,6,6"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,1,1"
                Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status dot -->
                <Ellipse x:ConnectionId='2' Grid.Column="0" Width="8" Height="8"
                         x:Name="StatusDot"
                         VerticalAlignment="Center" Margin="0,0,8,0" />

                <!-- Repo name -->
                <TextBlock x:ConnectionId='3' Grid.Column="1" x:Name="RepoNameText"
                           Text="—"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- PID -->
                <TextBlock x:ConnectionId='4' Grid.Column="2" x:Name="PidText"
                           FontSize="10" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontFamily="Cascadia Mono,Consolas,monospace"
                           Margin="8,0" />

                <!-- Close button (only in tab mode) -->
                <Button x:ConnectionId='5' Grid.Column="3" x:Name="CloseButton"
                        Padding="2" Width="20" Height="20"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center"
                                                 
                        ToolTipService.ToolTip="Close session">
                    <FontIcon Glyph="&#xE711;" FontSize="10" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>

