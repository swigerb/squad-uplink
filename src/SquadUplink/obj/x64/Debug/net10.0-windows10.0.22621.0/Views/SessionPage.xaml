<Page x:ConnectionId='1'
    x:Class="SquadUplink.Views.SessionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Views"
    xmlns:vm="using:SquadUplink.ViewModels"
    xmlns:converters="using:SquadUplink.Converters">

    <Page.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrush" />
        <converters:StatusToTextConverter x:Key="StatusToText" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="20,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Session Info Bar ═══ -->
        <Border Grid.Row="0" Style="{StaticResource CockpitPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16"
                            VerticalAlignment="Center">
                    <!-- Status Badge -->
                    <Border x:ConnectionId='11' CornerRadius="4" Padding="10,4"
                                                                                                                                >
                        <TextBlock x:ConnectionId='16'                                                                                              
                                   FontSize="11" FontWeight="SemiBold" Foreground="White" />
                    </Border>

                    <!-- Repo name -->
                    <TextBlock x:ConnectionId='12'                                                      
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               FontSize="15" VerticalAlignment="Center" />

                    <Border Width="1" Height="20"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- PID -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE943;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='15'                                                     
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" FontFamily="Cascadia Mono,Consolas,monospace" />
                    </StackPanel>

                    <Border Width="1" Height="20"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Working Directory -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8B7;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='14'                                                            
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="350"
                                   FontSize="12" FontFamily="Cascadia Mono,Consolas,monospace" />
                    </StackPanel>

                    <Border Width="1" Height="20"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Age -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE823;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='13'                                                  
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button x:ConnectionId='7'                                         
                            ToolTipService.ToolTip="Stop Session"
                            Background="#33F44336">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE71A;" FontSize="12" Foreground="#F44336" />
                            <TextBlock Text="Stop" Foreground="#F44336" />
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='8'                                            
                            ToolTipService.ToolTip="Restart Session"
                            Background="#332196F3">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="12" Foreground="#2196F3" />
                            <TextBlock Text="Restart" Foreground="#2196F3" />
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='9'                                                 
                            ToolTipService.ToolTip="Open in GitHub"
                                                                                                                           >
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE71B;" FontSize="12" />
                            <TextBlock Text="GitHub" />
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='10'                                                
                            ToolTipService.ToolTip="Copy Task URL"
                                                                                                                           >
                        <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ WebView2 Terminal ═══ -->
        <Border Grid.Row="1" CornerRadius="8" BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <WebView2 x:ConnectionId='6' x:Name="TerminalWebView"
                      Source="ms-appx-web:///wwwroot/terminal.html" />
        </Border>

        <!-- ═══ Collapsible Telemetry Panel ═══ -->
        <Expander Grid.Row="2" Header="Session Telemetry"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  IsExpanded="False">
            <Grid ColumnSpacing="24" Padding="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Output Lines -->
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="OUTPUT LINES" FontSize="10" CharacterSpacing="80"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='5'                                                       
                               FontSize="20" FontWeight="SemiBold" />
                </StackPanel>

                <!-- Last Activity -->
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="LAST ACTIVITY" FontSize="10" CharacterSpacing="80"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='4'                                                        
                               FontSize="13" />
                </StackPanel>

                <!-- Squad Info -->
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="SQUAD" FontSize="10" CharacterSpacing="80"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='3'                                                 
                               FontSize="13" />
                </StackPanel>

                <!-- Error Log -->
                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Text="ERRORS" FontSize="10" CharacterSpacing="80"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='2'                                                       
                               FontSize="13"
                               Foreground="{StaticResource SquadErrorRedBrush}" />
                </StackPanel>
            </Grid>
        </Expander>
    </Grid>
</Page>

