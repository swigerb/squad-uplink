<UserControl
    x:Class="SquadUplink.Controls.AgentRoiWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:SquadUplink.Models">

    <Border Style="{StaticResource CockpitPanelStyle}">
        <StackPanel Spacing="6">
            <TextBlock Text="AGENT ROI" Style="{StaticResource SectionHeaderStyle}"
                       CharacterSpacing="80" FontSize="10" />

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState"
                        Visibility="{x:Bind EmptyStateVisible, Mode=OneWay}"
                        HorizontalAlignment="Center" Spacing="4" Padding="0,8">
                <FontIcon Glyph="&#xE9D9;" FontSize="20" Opacity="0.4"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="No telemetry data yet"
                           FontSize="11" FontStyle="Italic" Opacity="0.5"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Table content -->
            <StackPanel x:Name="TableContent"
                        Visibility="{x:Bind TableVisible, Mode=OneWay}"
                        Spacing="0">

                <!-- Header row -->
                <Grid Padding="4,4" Opacity="0.7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Agent" FontSize="10" CharacterSpacing="60"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="1" Text="Tokens" FontSize="10" CharacterSpacing="60"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="2" Text="Cost" FontSize="10" CharacterSpacing="60"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="3" Text="Decisions" FontSize="10" CharacterSpacing="60"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="4" Text="$/Decision" FontSize="10" CharacterSpacing="60"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                </Grid>

                <!-- Separator -->
                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,2" />

                <!-- Data rows -->
                <ItemsRepeater x:Name="AgentRows"
                               ItemsSource="{x:Bind AgentItems, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:AgentRoiRow">
                            <Grid Padding="4,6"
                                  Background="{x:Bind RowBackground}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="12">
                                    <Run Text="{x:Bind Emoji}" /><Run Text=" " /><Run Text="{x:Bind AgentName}" />
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{x:Bind TokenDisplay}"
                                           FontSize="11" FontFamily="Cascadia Mono,Consolas,monospace"
                                           HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="2" Text="{x:Bind CostDisplay}"
                                           FontSize="11" FontFamily="Cascadia Mono,Consolas,monospace"
                                           HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="{x:Bind DecisionDisplay}"
                                           FontSize="11" FontFamily="Cascadia Mono,Consolas,monospace"
                                           HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="4" Text="{x:Bind CostPerDecisionDisplay}"
                                           FontSize="11" FontFamily="Cascadia Mono,Consolas,monospace"
                                           HorizontalAlignment="Right"
                                           Foreground="{x:Bind CostPerDecisionBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
