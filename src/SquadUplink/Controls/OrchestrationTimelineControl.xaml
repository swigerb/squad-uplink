<UserControl
    x:Class="SquadUplink.Controls.OrchestrationTimelineControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Controls"
    xmlns:models="using:SquadUplink.Models">

    <Border Style="{StaticResource CockpitPanelStyle}">
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE916;" FontSize="14"
                          Foreground="{StaticResource SquadWarningYellowBrush}" />
                <TextBlock Text="ORCHESTRATION TIMELINE"
                           Style="{StaticResource SectionHeaderStyle}"
                           CharacterSpacing="80" FontSize="11" />
            </StackPanel>

            <!-- Timeline List (newest at top) -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="300">
                <ItemsRepeater x:Name="TimelineList"
                               ItemsSource="{x:Bind Entries, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:OrchestrationEntry">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Timeline connector line + emoji -->
                                <Grid Grid.Column="0" Width="36" Margin="0,0,4,0">
                                    <Border Width="2"
                                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Stretch" />
                                    <Border Width="28" Height="28"
                                            CornerRadius="14"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{x:Bind AgentEmoji, Mode=OneTime}"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>

                                <!-- Timestamp -->
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Timestamp, Mode=OneTime}"
                                           FontSize="10"
                                           Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                           VerticalAlignment="Top"
                                           Margin="0,4,8,0"
                                           Width="68" />

                                <!-- Content card -->
                                <Border Grid.Column="2"
                                        Padding="10,8" CornerRadius="4"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <StackPanel Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind AgentName, Mode=OneTime}"
                                                       FontSize="12" FontWeight="SemiBold" />
                                            <Border CornerRadius="3" Padding="6,1"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                <TextBlock Text="{x:Bind Outcome, Mode=OneTime}"
                                                           FontSize="10"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Summary, Mode=OneTime}"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   MaxLines="3" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Grid.Row="1"
                       x:Name="EmptyText"
                       Visibility="{x:Bind NoEntriesVisible, Mode=OneWay}"
                       Text="No orchestration logs"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorDisabledBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,12" />
        </Grid>
    </Border>
</UserControl>
