<UserControl
    x:Class="SquadUplink.Controls.TokenGaugeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center" Spacing="4">
        <!-- Circular gauge -->
        <Grid Width="80" Height="80">
            <ProgressRing x:Name="GaugeRing"
                          Width="80" Height="80"
                          IsIndeterminate="False"
                          Value="{x:Bind Percentage, Mode=OneWay}"
                          Foreground="{x:Bind GaugeBrush, Mode=OneWay}" />
            <TextBlock x:Name="PercentText"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="15" FontWeight="Bold"
                       Text="{x:Bind PercentageDisplay, Mode=OneWay}" />
        </Grid>

        <!-- Label -->
        <TextBlock Text="TOKENS"
                   FontSize="10" CharacterSpacing="80"
                   HorizontalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- Cost display -->
        <TextBlock x:Name="CostText"
                   Text="{x:Bind CostDisplay, Mode=OneWay}"
                   FontSize="11"
                   FontFamily="Cascadia Mono,Consolas,monospace"
                   HorizontalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </StackPanel>
</UserControl>
