<UserControl
    x:Class="SquadUplink.Controls.ContextPressureWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CockpitPanelStyle}">
        <StackPanel Spacing="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="CONTEXT WINDOW" Style="{StaticResource SectionHeaderStyle}"
                           CharacterSpacing="80" FontSize="10" />

                <!-- Warning icon when >80% -->
                <FontIcon x:Name="WarningIcon" Grid.Column="1"
                          Glyph="&#xE7BA;" FontSize="14"
                          Foreground="{StaticResource SquadErrorRedBrush}"
                          Visibility="{x:Bind WarningVisible, Mode=OneWay}" />
            </Grid>

            <!-- Pressure label: "42% of 128K" -->
            <TextBlock x:Name="PressureLabel"
                       Text="{x:Bind PressureDisplay, Mode=OneWay}"
                       FontSize="18" FontWeight="SemiBold"
                       FontFamily="Cascadia Mono,Consolas,monospace" />

            <!-- Horizontal progress bar with color segments -->
            <ProgressBar x:Name="PressureBar"
                         Height="12"
                         Minimum="0" Maximum="100"
                         Value="{x:Bind PressurePercent, Mode=OneWay}"
                         Foreground="{x:Bind PressureBrush, Mode=OneWay}"
                         CornerRadius="4" />

            <!-- Token count detail -->
            <TextBlock x:Name="TokenDetail"
                       Text="{x:Bind TokenDetailDisplay, Mode=OneWay}"
                       Style="{StaticResource StatLabelTextStyle}" />

            <!-- Warning text when >80% -->
            <TextBlock x:Name="WarningText"
                       Text="⚠ Squad may lose context"
                       FontSize="11" FontStyle="Italic"
                       Foreground="{StaticResource SquadErrorRedBrush}"
                       Visibility="{x:Bind WarningVisible, Mode=OneWay}" />
        </StackPanel>
    </Border>
</UserControl>
