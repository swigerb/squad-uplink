<UserControl
    x:Class="SquadUplink.Controls.SquadTreeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Controls"
    xmlns:models="using:SquadUplink.Models">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <FontIcon Glyph="&#xE716;" FontSize="14"
                      Foreground="{StaticResource SquadAccentGreenBrush}" />
            <TextBlock Text="SQUAD TREE" Style="{StaticResource SectionHeaderStyle}"
                       CharacterSpacing="80" FontSize="11" />
        </StackPanel>

        <!-- TreeView for squad hierarchy -->
        <TreeView Grid.Row="1"
                  x:Name="SquadTree"
                  SelectionMode="Single"
                  ItemInvoked="SquadTree_ItemInvoked"
                  Visibility="{x:Bind HasSquads, Mode=OneWay}"
                  AutomationProperties.Name="Squad hierarchy tree">
            <TreeView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,2" Padding="8,6" CornerRadius="4"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                       FontSize="16" VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayText}"
                                           FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Role}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <TextBlock Text="{Binding StatusText}" FontSize="10" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- No Squad Placeholder -->
        <StackPanel Grid.Row="1"
                    x:Name="NoSquadPanel"
                    Visibility="{x:Bind NoSquadsVisible, Mode=OneWay}"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="8">
            <FontIcon Glyph="&#xE946;" FontSize="32"
                      Foreground="{ThemeResource TextFillColorDisabledBrush}"
                      HorizontalAlignment="Center" />
            <TextBlock Text="No Squad detected"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" FontSize="12" />
            <TextBlock Text="Open a repo with .squad/ to see your team"
                       Foreground="{ThemeResource TextFillColorDisabledBrush}"
                       HorizontalAlignment="Center" FontSize="11"
                       TextWrapping="Wrap" TextAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
