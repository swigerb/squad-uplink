<UserControl
    x:Class="SquadUplink.Controls.CommandPalette"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Full-screen overlay -->
    <Grid x:Name="OverlayRoot" Visibility="Collapsed">
        <!-- Semi-transparent dark backdrop -->
        <Border Background="#CC000000"
                Tapped="Overlay_Tapped" />

        <!-- Centered palette panel -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,80,0,0" Width="560" MaxHeight="480"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{StaticResource SquadAccentGreenBrush}"
                BorderThickness="1"
                Padding="0">
            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Search box -->
                <AutoSuggestBox x:Name="SearchBox"
                                Grid.Row="0"
                                PlaceholderText="Type a command..."
                                QueryIcon="Find"
                                Margin="16,16,16,8"
                                TextChanged="SearchBox_TextChanged"
                                QuerySubmitted="SearchBox_QuerySubmitted" />

                <!-- Command list -->
                <ListView x:Name="CommandList"
                          Grid.Row="1"
                          Margin="8,0,8,8"
                          MaxHeight="360"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="CommandList_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="{Binding IconGlyph}"
                                          FontSize="16" VerticalAlignment="Center"
                                          Foreground="{StaticResource SquadAccentGreenBrush}" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>
