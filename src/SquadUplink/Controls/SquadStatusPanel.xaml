<UserControl
    x:Class="SquadUplink.Controls.SquadStatusPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Controls"
    xmlns:models="using:SquadUplink.Models">

    <Border Style="{StaticResource CockpitPanelStyle}">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- No Selection State -->
            <StackPanel x:Name="NoSelectionPanel" Grid.Row="0" Grid.RowSpan="4"
                        Visibility="{x:Bind NoSelectionVisible, Mode=OneWay}"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8FB;" FontSize="24"
                          Foreground="{ThemeResource TextFillColorDisabledBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Select a squad to view details"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" FontSize="12" />
            </StackPanel>

            <!-- Squad Header -->
            <StackPanel Grid.Row="0" Spacing="4"
                        Visibility="{x:Bind HasSelection, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE716;" FontSize="18"
                              Foreground="{StaticResource SquadAccentGreenBrush}" />
                    <TextBlock Text="{x:Bind TeamName, Mode=OneWay}"
                               FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE774;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind UniverseText, Mode=OneWay}"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE77B;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind MemberCountText, Mode=OneWay}"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Current Focus Callout -->
            <Border Grid.Row="1"
                    Visibility="{x:Bind HasSelection, Mode=OneWay}"
                    Background="{StaticResource SquadAccentGreenBrush}"
                    Opacity="0.15" CornerRadius="6" Padding="12,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="CURRENT FOCUS" FontSize="10"
                               CharacterSpacing="80" FontWeight="SemiBold"
                               Foreground="White" Opacity="0.8" />
                    <TextBlock Text="{x:Bind CurrentFocusText, Mode=OneWay}"
                                   FontSize="13" Foreground="White"
                                   TextWrapping="Wrap" />
                    </StackPanel>
            </Border>

            <!-- Decisions Summary -->
            <StackPanel Grid.Row="2" Spacing="4"
                        Visibility="{x:Bind HasSelection, Mode=OneWay}">
                <TextBlock Text="RECENT DECISIONS" FontSize="10"
                           CharacterSpacing="80"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="{x:Bind DecisionsSummary, Mode=OneWay}"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           MaxHeight="60" />
            </StackPanel>

            <!-- Member Cards -->
            <ScrollViewer Grid.Row="3"
                          Visibility="{x:Bind HasSelection, Mode=OneWay}"
                          VerticalScrollBarVisibility="Auto">
                <ItemsRepeater x:Name="MemberList"
                               ItemsSource="{x:Bind MemberItems, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:SquadTreeItem">
                            <Border Margin="0,2" Padding="8,6" CornerRadius="4"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Icon, Mode=OneTime}"
                                               FontSize="16" VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind DisplayText, Mode=OneTime}"
                                                   FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind Role, Mode=OneTime}" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                        <TextBlock Text="{x:Bind StatusText, Mode=OneTime}" FontSize="10" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
