<Window
    x:Class="SquadUplink.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Squad Uplink">

    <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0d1117" Offset="0"/>
                <GradientStop Color="#161b22" Offset="0.5"/>
                <GradientStop Color="#0d1117" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.Resources>
            <!-- Logo pulse animation -->
            <Storyboard x:Name="PulseAnimation">
                <DoubleAnimation
                    Storyboard.TargetName="LogoScale"
                    Storyboard.TargetProperty="ScaleX"
                    From="1" To="1.03"
                    Duration="0:0:1"
                    AutoReverse="True"
                    RepeatBehavior="Forever">
                    <DoubleAnimation.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="LogoScale"
                    Storyboard.TargetProperty="ScaleY"
                    From="1" To="1.03"
                    Duration="0:0:1"
                    AutoReverse="True"
                    RepeatBehavior="Forever">
                    <DoubleAnimation.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Loading text fade -->
            <Storyboard x:Name="FadeAnimation">
                <DoubleAnimation
                    Storyboard.TargetName="LoadingText"
                    Storyboard.TargetProperty="Opacity"
                    From="0.5" To="1"
                    Duration="0:0:0.75"
                    AutoReverse="True"
                    RepeatBehavior="Forever">
                    <DoubleAnimation.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">

            <!-- Logo container -->
            <Border Width="200" Height="100" CornerRadius="20"
                    RenderTransformOrigin="0.5,0.5"
                    HorizontalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3fb950" Offset="0"/>
                        <GradientStop Color="#58a6ff" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="LogoScale"/>
                </Border.RenderTransform>
                <TextBlock Text="🚀 Squad Uplink"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#0d1117"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Loading text -->
            <TextBlock x:Name="LoadingText"
                       Text="Loading..."
                       FontSize="13"
                       Foreground="#8b949e"
                       HorizontalAlignment="Center"
                       Opacity="0.5"/>

            <!-- Progress ring -->
            <ProgressRing IsActive="True" Width="32" Height="32"
                          HorizontalAlignment="Center"
                          Foreground="#3fb950"/>

        </StackPanel>

        <!-- Version at bottom -->
        <TextBlock x:Name="VersionText"
                   FontSize="11"
                   Foreground="#484f58"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,16"/>
    </Grid>
</Window>
