<Page
    x:Class="SquadUplink.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Views"
    xmlns:vm="using:SquadUplink.ViewModels"
    xmlns:models="using:SquadUplink.Models"
    xmlns:converters="using:SquadUplink.Converters">

    <Page.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrush" />
        <converters:StatusToTextConverter x:Key="StatusToText" />
        <converters:TimeAgoConverter x:Key="TimeAgo" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </Page.Resources>

    <Grid ColumnSpacing="12" RowSpacing="12" Padding="20,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ TOP BAR ═══ (spans all columns) -->
        <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AutoSuggestBox Grid.Column="0"
                            PlaceholderText="&#xE721;  Search sessions..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchFilter, Mode=TwoWay}"
                            Width="320" HorizontalAlignment="Left"
                            VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                <ToggleButton x:Name="GridViewToggle" Content="&#xF0E2;"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              IsChecked="{x:Bind ViewModel.IsGridView, Mode=TwoWay}"
                              ToolTipService.ToolTip="Grid View" Width="36" Height="36" Padding="0" />
                <ToggleButton x:Name="TabViewToggle" Content="&#xE8A0;"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              IsChecked="{x:Bind ViewModel.IsTabView, Mode=TwoWay}"
                              ToolTipService.ToolTip="Tab View" Width="36" Height="36" Padding="0" />
            </StackPanel>

            <Button Grid.Column="2" Command="{x:Bind ViewModel.RefreshCommand}"
                    ToolTipService.ToolTip="Refresh" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <!-- ═══ LEFT PANEL — Squad Tree ═══ -->
        <Border Grid.Column="0" Grid.Row="1"
                Style="{StaticResource CockpitPanelStyle}">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE716;" FontSize="14"
                              Foreground="{StaticResource SquadAccentGreenBrush}" />
                    <TextBlock Text="SQUAD TREE" Style="{StaticResource SectionHeaderStyle}"
                               CharacterSpacing="80" FontSize="11" />
                </StackPanel>

                <!-- Squad Members List -->
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.SquadTreeItems, Mode=OneWay}"
                          SelectionMode="None"
                          Visibility="{x:Bind ViewModel.HasSquads, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SquadTreeItem">
                            <Grid Padding="{x:Bind local:DashboardPage.GetIndentPadding(IndentLevel)}"
                                  Height="32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Icon}"
                                           FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{x:Bind DisplayText}"
                                           VerticalAlignment="Center"
                                           FontWeight="{x:Bind local:DashboardPage.GetFontWeight(IsHeader)}"
                                           FontSize="{x:Bind local:DashboardPage.GetFontSize(IsHeader)}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind StatusText}"
                                           FontSize="10" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- No Squad Placeholder -->
                <StackPanel Grid.Row="1"
                            Visibility="{x:Bind ViewModel.NoSquadsVisible, Mode=OneWay}"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="8">
                    <FontIcon Glyph="&#xE716;" FontSize="32"
                              Foreground="{ThemeResource TextFillColorDisabledBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No Squad detected"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" FontSize="12" />
                    <TextBlock Text="Open a repo with .squad/ to see your team"
                               Foreground="{ThemeResource TextFillColorDisabledBrush}"
                               HorizontalAlignment="Center" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CENTER — Session Grid ═══ -->
        <ScrollViewer Grid.Column="1" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <GridView ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="SessionCard_ItemClick">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:SessionState">
                            <Border Style="{StaticResource SessionCardStyle}"
                                    Width="290" Height="190" Margin="4">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Repo name + Status badge -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind RepositoryName, Mode=OneWay}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   FontSize="15"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="1" CornerRadius="4"
                                                Padding="8,2"
                                                Background="{x:Bind Status, Mode=OneWay, Converter={StaticResource StatusToBrush}}">
                                            <TextBlock Text="{x:Bind Status, Mode=OneWay, Converter={StaticResource StatusToText}}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="White" />
                                        </Border>
                                    </Grid>

                                    <!-- Working directory -->
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind WorkingDirectory, Mode=OneWay}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               FontFamily="Cascadia Mono,Consolas,monospace" />

                                    <!-- PID + Age -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE943;" FontSize="10"
                                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="PID " /><Run Text="{x:Bind ProcessId, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE823;" FontSize="10"
                                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="{x:Bind StartedAt, Mode=OneWay, Converter={StaticResource TimeAgo}}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Activity sparkline placeholder -->
                                    <Border Grid.Row="3" CornerRadius="4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            Padding="4" Margin="0,4">
                                        <Grid Height="24">
                                            <!-- Simulated sparkline bars -->
                                            <StackPanel Orientation="Horizontal" Spacing="2"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Stretch">
                                                <Border Width="3" Height="8" CornerRadius="1"
                                                        Background="{StaticResource SquadAccentGreenBrush}" Opacity="0.3" />
                                                <Border Width="3" Height="14" CornerRadius="1"
                                                        Background="{StaticResource SquadAccentGreenBrush}" Opacity="0.5" />
                                                <Border Width="3" Height="6" CornerRadius="1"
                                                        Background="{StaticResource SquadAccentGreenBrush}" Opacity="0.3" />
                                                <Border Width="3" Height="18" CornerRadius="1"
                                                        Background="{StaticResource SquadAccentGreenBrush}" Opacity="0.7" />
                                                <Border Width="3" Height="10" CornerRadius="1"
                                                        Background="{StaticResource SquadAccentGreenBrush}" Opacity="0.4" />
                                                <Border Width="3" Height="22" CornerRadius="1"
                                                        Background="{StaticResource SquadAccentGreenBrush}" Opacity="0.9" />
                                                <Border Width="3" Height="12" CornerRadius="1"
                                                        Background="{StaticResource SquadAccentGreenBrush}" Opacity="0.5" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- GitHub link -->
                                    <HyperlinkButton Grid.Row="4"
                                                     Content="{x:Bind GitHubTaskUrl, Mode=OneWay}"
                                                     NavigateUri="{x:Bind GitHubTaskUrl, Mode=OneWay}"
                                                     Visibility="{x:Bind GitHubTaskUrl, Mode=OneWay, Converter={StaticResource NullToVisibility}}"
                                                     FontSize="11" Padding="0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!-- Launch New Session Card -->
                <Button Command="{x:Bind ViewModel.LaunchSessionCommand}"
                        HorizontalAlignment="Left" Margin="4,0"
                        Padding="0" Background="Transparent" BorderThickness="0">
                    <Border Style="{StaticResource LaunchCardStyle}"
                            Width="290" Height="190">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center" Spacing="12">
                            <FontIcon Glyph="&#xE710;" FontSize="36"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="Launch New Session"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ RIGHT PANEL — Stats &amp; Graphs ═══ -->
        <ScrollViewer Grid.Column="2" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <!-- Active Sessions Counter -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="ACTIVE SESSIONS" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <TextBlock Text="{x:Bind ViewModel.ActiveSessionCount, Mode=OneWay}"
                                   Style="{StaticResource StatCounterTextStyle}"
                                   Foreground="{StaticResource SquadAccentGreenBrush}" />
                        <TextBlock Text="live sessions being tracked"
                                   Style="{StaticResource StatLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <!-- Total Uptime -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="TOTAL UPTIME" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <TextBlock Text="{x:Bind ViewModel.TotalUptime, Mode=OneWay}"
                                   Style="{StaticResource StatCounterTextStyle}"
                                   FontSize="28" />
                        <TextBlock Text="combined session runtime"
                                   Style="{StaticResource StatLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <!-- Messages Processed -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="MESSAGES" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <TextBlock Text="{x:Bind ViewModel.MessagesProcessed, Mode=OneWay}"
                                   Style="{StaticResource StatCounterTextStyle}" FontSize="28" />
                        <TextBlock Text="output lines captured"
                                   Style="{StaticResource StatLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <!-- CPU &amp; Memory Gauges -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- CPU Gauge -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                            <Grid Width="64" Height="64">
                                <ProgressRing Style="{StaticResource GaugeRingStyle}"
                                              Value="{x:Bind ViewModel.CpuUsage, Mode=OneWay}"
                                              Foreground="{StaticResource SquadAccentBlueBrush}" />
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold">
                                    <Run Text="{x:Bind ViewModel.CpuUsageDisplay, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                            <TextBlock Text="CPU" Style="{StaticResource StatLabelTextStyle}" />
                        </StackPanel>

                        <!-- Memory Gauge -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                            <Grid Width="64" Height="64">
                                <ProgressRing Style="{StaticResource GaugeRingStyle}"
                                              Value="{x:Bind ViewModel.MemoryUsage, Mode=OneWay}"
                                              Foreground="{StaticResource SquadWarningYellowBrush}" />
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold">
                                    <Run Text="{x:Bind ViewModel.MemoryUsageDisplay, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                            <TextBlock Text="MEM" Style="{StaticResource StatLabelTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Session Activity Chart Placeholder -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="SESSION ACTIVITY" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <Grid Height="80">
                            <!-- Bar chart simulation -->
                            <StackPanel Orientation="Horizontal" Spacing="4"
                                        VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Border Width="16" Height="20" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.3" />
                                <Border Width="16" Height="35" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.5" />
                                <Border Width="16" Height="55" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.7" />
                                <Border Width="16" Height="42" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.6" />
                                <Border Width="16" Height="70" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.9" />
                                <Border Width="16" Height="48" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.6" />
                                <Border Width="16" Height="30" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.4" />
                                <Border Width="16" Height="60" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.8" />
                                <Border Width="16" Height="25" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.3" />
                                <Border Width="16" Height="50" CornerRadius="2,2,0,0"
                                        Background="{StaticResource SquadAccentBlueBrush}" Opacity="0.7" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="msgs/min over last hour"
                                   Style="{StaticResource StatLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <!-- Error Count -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE7BA;" FontSize="20"
                                  Foreground="{StaticResource SquadErrorRedBrush}" />
                        <StackPanel>
                            <TextBlock FontSize="11" CharacterSpacing="80"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="ERRORS" />
                            <TextBlock Text="{x:Bind ViewModel.ErrorCount, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource SquadErrorRedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
