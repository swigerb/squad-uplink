<Page
    x:Class="SquadUplink.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Views"
    xmlns:vm="using:SquadUplink.ViewModels"
    xmlns:models="using:SquadUplink.Models"
    xmlns:controls="using:SquadUplink.Controls"
    xmlns:converters="using:SquadUplink.Converters">

    <Page.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrush" />
        <converters:StatusToTextConverter x:Key="StatusToText" />
        <converters:TimeAgoConverter x:Key="TimeAgo" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid ColumnSpacing="12" RowSpacing="12" Padding="20,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ TOP BAR ═══ (spans all columns) -->
        <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AutoSuggestBox Grid.Column="0"
                            PlaceholderText="&#xE721;  Search sessions..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchFilter, Mode=TwoWay}"
                            Width="320" HorizontalAlignment="Left"
                            VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                <!-- Cards / Tabs / Grid toggle -->
                <ToggleButton x:Name="CardsViewToggle" Content="&#xF0E2;"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              IsChecked="{x:Bind ViewModel.IsCardsView, Mode=TwoWay}"
                              ToolTipService.ToolTip="Cards View" Width="36" Height="36" Padding="0" />
                <ToggleButton x:Name="TabViewToggle" Content="&#xE8A0;"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              IsChecked="{x:Bind ViewModel.IsTabView, Mode=TwoWay}"
                              ToolTipService.ToolTip="Tab View" Width="36" Height="36" Padding="0" />
                <ToggleButton x:Name="GridViewToggle" Content="&#xE80A;"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              IsChecked="{x:Bind ViewModel.IsGridView, Mode=TwoWay}"
                              ToolTipService.ToolTip="Grid View" Width="36" Height="36" Padding="0" />

                <!-- Grid Size Selector (visible only in grid mode) -->
                <ComboBox x:Name="GridSizeSelector"
                          ItemsSource="{x:Bind ViewModel.GridSizeOptions}"
                          SelectedIndex="{x:Bind ViewModel.SelectedGridSizeIndex, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.IsGridSizeSelectorVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                          Width="80" Height="36"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Grid Size" />
            </StackPanel>

            <Button Grid.Column="2" Command="{x:Bind ViewModel.RefreshCommand}"
                    ToolTipService.ToolTip="Refresh" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <!-- ═══ LEFT PANEL — Squad Tree + Status ═══ -->
        <Grid Grid.Column="0" Grid.Row="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Squad Tree Control -->
            <Border Grid.Row="0" Style="{StaticResource CockpitPanelStyle}">
                <controls:SquadTreeControl
                    x:Name="SquadTreeView"
                    Squads="{x:Bind ViewModel.Squads, Mode=OneWay}"
                    SquadSelected="SquadTreeView_SquadSelected" />
            </Border>

            <!-- Squad Status Panel -->
            <controls:SquadStatusPanel Grid.Row="1"
                x:Name="SquadStatusDetail"
                SelectedSquad="{x:Bind ViewModel.SelectedSquad, Mode=OneWay}"
                MaxHeight="280" />
        </Grid>

        <!-- ═══ CENTER — Session Layout (Cards / Tab / Grid) ═══ -->
        <Grid Grid.Column="1" Grid.Row="1">
            <!-- Cards View (default) -->
            <ScrollViewer x:Name="CardsScrollViewer"
                          Visibility="{x:Bind ViewModel.IsCardsView, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,8,0">
                <StackPanel Spacing="0">
                    <!-- Empty State -->
                    <StackPanel Visibility="{x:Bind ViewModel.HasNoSessions, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="16" Padding="40">
                        <FontIcon Glyph="&#xE774;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="No sessions found"
                                   HorizontalAlignment="Center"
                                   FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Click Launch to start a new Copilot CLI session"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />
                        <Button Content="Launch Session"
                                HorizontalAlignment="Center"
                                Command="{x:Bind ViewModel.LaunchSessionCommand}"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>

                    <!-- Session Cards Grid -->
                    <ItemsRepeater x:Name="SessionCardsRepeater"
                                   ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="320" MinItemHeight="160"
                                               MinColumnSpacing="12" MinRowSpacing="12"
                                               ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:SessionState">
                                <Border Style="{StaticResource SessionCardStyle}"
                                        PointerPressed="SessionCard_PointerPressed"
                                        Tag="{x:Bind}">
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Repo name + Status badge -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind RepositoryName, Mode=OneWay, TargetNullValue='Unknown'}"
                                                       FontWeight="Bold" FontSize="15"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" CornerRadius="4" Padding="8,3"
                                                    Background="{x:Bind Status, Mode=OneWay, Converter={StaticResource StatusToBrush}}">
                                                <TextBlock Text="{x:Bind Status, Mode=OneWay, Converter={StaticResource StatusToText}}"
                                                           FontSize="10" FontWeight="SemiBold" Foreground="White" />
                                            </Border>
                                        </Grid>

                                        <!-- Row 1: PID + Age -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE943;" FontSize="11"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock FontSize="11" FontFamily="Cascadia Mono,Consolas,monospace"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="PID " /><Run Text="{x:Bind ProcessId, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE823;" FontSize="11"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind StartedAt, Mode=OneWay, Converter={StaticResource TimeAgo}}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Row 2: Working directory (truncated) -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="11"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind WorkingDirectory, Mode=OneWay}"
                                                       FontSize="11" FontFamily="Cascadia Mono,Consolas,monospace"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="280" />
                                        </StackPanel>

                                        <!-- Row 4: GitHub link + indicators -->
                                        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                                            <HyperlinkButton Content="Open in GitHub"
                                                             NavigateUri="{x:Bind GitHubTaskUri, Mode=OneWay}"
                                                             Visibility="{x:Bind HasGitHubUrl, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                                             FontSize="11" Padding="0" />
                                            <FontIcon Glyph="&#xE71B;" FontSize="12"
                                                      Foreground="{StaticResource SquadAccentGreenBrush}"
                                                      Visibility="{x:Bind HasGitHubUrl, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                                      ToolTipService.ToolTip="Has GitHub task URL" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Launch New Session Card -->
                    <Border Style="{StaticResource LaunchCardStyle}"
                            Margin="0,12,0,0" MinHeight="120"
                            PointerPressed="LaunchCard_PointerPressed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="28"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      HorizontalAlignment="Center" />
                            <TextBlock Text="Launch New Session"
                                       HorizontalAlignment="Center"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Tab / Grid layout (existing) -->
            <controls:SessionLayoutControl
                x:Name="SessionLayout"
                Visibility="{x:Bind ViewModel.IsCardsView, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                LayoutMode="{x:Bind ViewModel.CurrentLayoutMode, Mode=OneWay}"
                Sessions="{x:Bind ViewModel.Sessions, Mode=OneWay}"
                GridSize="{x:Bind ViewModel.CurrentGridSize, Mode=OneWay}"
                SelectedSessionIndex="{x:Bind ViewModel.SelectedSessionIndex, Mode=TwoWay}"
                SessionCloseRequested="SessionLayout_SessionCloseRequested"
                LaunchNewRequested="SessionLayout_LaunchNewRequested"
                SessionFocusRequested="SessionLayout_SessionFocusRequested" />
        </Grid>

        <!-- ═══ RIGHT PANEL — Stats &amp; Graphs ═══ -->
        <ScrollViewer Grid.Column="2" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <!-- Active Sessions Counter -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="ACTIVE SESSIONS" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <TextBlock Text="{x:Bind ViewModel.ActiveSessionCount, Mode=OneWay}"
                                   Style="{StaticResource StatCounterTextStyle}"
                                   Foreground="{StaticResource SquadAccentGreenBrush}" />
                        <TextBlock Text="live sessions being tracked"
                                   Style="{StaticResource StatLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <!-- Total Uptime -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="TOTAL UPTIME" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <TextBlock Text="{x:Bind ViewModel.TotalUptime, Mode=OneWay}"
                                   Style="{StaticResource StatCounterTextStyle}"
                                   FontSize="28" />
                        <TextBlock Text="since app launched"
                                   Style="{StaticResource StatLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <!-- Messages Processed -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="MESSAGES" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <TextBlock Text="{x:Bind ViewModel.MessagesProcessed, Mode=OneWay}"
                                   Style="{StaticResource StatCounterTextStyle}" FontSize="28" />
                        <TextBlock Text="output lines captured"
                                   Style="{StaticResource StatLabelTextStyle}" />
                    </StackPanel>
                </Border>

                <!-- CPU &amp; Memory Gauges -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- CPU Gauge -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                            <Grid Width="64" Height="64">
                                <ProgressRing Style="{StaticResource GaugeRingStyle}"
                                              Value="{x:Bind ViewModel.CpuUsage, Mode=OneWay}"
                                              Foreground="{StaticResource SquadAccentBlueBrush}" />
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold">
                                    <Run Text="{x:Bind ViewModel.CpuUsageDisplay, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                            <TextBlock Text="CPU" Style="{StaticResource StatLabelTextStyle}" />
                        </StackPanel>

                        <!-- Memory Gauge -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                            <Grid Width="64" Height="64">
                                <ProgressRing Style="{StaticResource GaugeRingStyle}"
                                              Value="{x:Bind ViewModel.MemoryUsage, Mode=OneWay}"
                                              Foreground="{StaticResource SquadWarningYellowBrush}" />
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold">
                                    <Run Text="{x:Bind ViewModel.MemoryUsageDisplay, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                            <TextBlock Text="MEM" Style="{StaticResource StatLabelTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Token Usage Gauge -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="TOKEN USAGE" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <controls:TokenGaugeControl x:Name="TokenGauge" />
                    </StackPanel>
                </Border>

                <!-- Session Activity — Empty State -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="SESSION ACTIVITY" Style="{StaticResource SectionHeaderStyle}"
                                   CharacterSpacing="80" FontSize="10" />
                        <Grid Height="80">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE9D9;" FontSize="24" Opacity="0.4"
                                          HorizontalAlignment="Center"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="No activity data"
                                           FontSize="11" FontStyle="Italic" Opacity="0.5"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Error Count -->
                <Border Style="{StaticResource CockpitPanelStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE7BA;" FontSize="20"
                                  Foreground="{StaticResource SquadErrorRedBrush}" />
                        <StackPanel>
                            <TextBlock FontSize="11" CharacterSpacing="80"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="ERRORS" />
                            <TextBlock Text="{x:Bind ViewModel.ErrorCount, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource SquadErrorRedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Decision Feed (Phase C) -->
                <controls:DecisionFeedControl
                    x:Name="DecisionFeed"
                    Decisions="{x:Bind ViewModel.DecisionFeed, Mode=OneWay}" />

                <!-- Orchestration Timeline (Phase C) -->
                <controls:OrchestrationTimelineControl
                    x:Name="OrchestrationTimeline"
                    Entries="{x:Bind ViewModel.OrchestrationTimeline, Mode=OneWay}" />

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
