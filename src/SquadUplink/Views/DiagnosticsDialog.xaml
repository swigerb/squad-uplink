<ContentDialog
    x:Class="SquadUplink.Views.DiagnosticsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SquadUplink.Converters"
    Title="Application Diagnostics"
    FullSizeDesired="True"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <converters:LevelToBrushConverter x:Key="LevelToBrushConverter"/>
        <converters:LevelToForegroundConverter x:Key="LevelToForegroundConverter"/>
        <converters:PayloadTypeToStringConverter x:Key="PayloadTypeToStringConverter"/>
        <converters:PayloadTypeToVisibilityConverter x:Key="PayloadTypeToVisibilityConverter"/>
    </ContentDialog.Resources>

    <Grid MinHeight="450" MaxHeight="800">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Filter bar -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <ComboBox x:Name="LevelFilter" MinWidth="140" PlaceholderText="Filter by level"
                      SelectionChanged="LevelFilter_Changed"
                      AutomationProperties.Name="Log level filter">
                <ComboBoxItem Content="All Levels" IsSelected="True" Tag="All"/>
                <ComboBoxItem Content="🔴 Errors Only" Tag="Error"/>
                <ComboBoxItem Content="🟡 Warnings &amp; Above" Tag="Warning"/>
                <ComboBoxItem Content="ℹ️ Info &amp; Above" Tag="Information"/>
                <ComboBoxItem Content="🔍 Debug (All)" Tag="Debug"/>
            </ComboBox>
            <AutoSuggestBox PlaceholderText="Search messages…"
                            Width="220" QueryIcon="Find"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            AutomationProperties.Name="Search log messages"/>
            <!-- Entry count badge: "42 / 1000" -->
            <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                <TextBlock Text="{Binding EntryCount}" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Opacity="0.7"/>
                <TextBlock Text="/" FontSize="11" Opacity="0.4"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalCount}" FontSize="11" Opacity="0.4"
                           VerticalAlignment="Center"/>
                <TextBlock Text="entries" FontSize="11" Opacity="0.4"
                           VerticalAlignment="Center" Margin="2,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Row 1: Source filter toggles -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="0,0,0,16"
                      Margin="0,0,0,6">
            <ItemsControl ItemsSource="{Binding AvailableSources}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton Content="{Binding Name}"
                                      IsChecked="{Binding IsActive, Mode=TwoWay}"
                                      FontSize="11" Padding="8,3"
                                      MinHeight="0" MinWidth="0"
                                      AutomationProperties.Name="{Binding Name}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 2: Log entries with expandable detail rows -->
        <ListView Grid.Row="2" x:Name="LogList"
                  ItemsSource="{Binding FilteredEntries}"
                  SelectionMode="None" Padding="0"
                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="Diagnostic log entries">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Expander HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                              Padding="0" Margin="0,0,0,1">

                        <!-- Collapsed header: single-line summary -->
                        <Expander.Header>
                            <Grid Padding="4,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="78"/>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Timestamp -->
                                <TextBlock Text="{Binding Time}" FontSize="11"
                                           FontFamily="Cascadia Code, Cascadia Mono, Consolas"
                                           Opacity="0.5" VerticalAlignment="Center"/>

                                <!-- Severity badge (Border pill — NOT InfoBadge) -->
                                <Border Grid.Column="1" CornerRadius="4" Padding="5,1"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="{Binding Level, Converter={StaticResource LevelToBrushConverter}}">
                                    <TextBlock Text="{Binding LevelTag}" FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding Level, Converter={StaticResource LevelToForegroundConverter}}"/>
                                </Border>

                                <!-- Source context -->
                                <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="11"
                                           Opacity="0.6" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTipService.ToolTip="{Binding Source}"/>

                                <!-- Truncated message -->
                                <TextBlock Grid.Column="3" Text="{Binding ShortMessage}" FontSize="11"
                                           TextTrimming="CharacterEllipsis" MaxLines="1"
                                           VerticalAlignment="Center"
                                           ToolTipService.ToolTip="{Binding ShortMessage}"/>
                            </Grid>
                        </Expander.Header>

                        <!-- Expanded content: full payload + copy button -->
                        <Expander.Content>
                            <Grid Padding="8" Margin="4,0,4,4"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                  CornerRadius="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Payload type badge + Copy button -->
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            Margin="0,0,0,6">
                                    <Border CornerRadius="3" Padding="6,2"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            Visibility="{Binding PayloadType, Converter={StaticResource PayloadTypeToVisibilityConverter}}">
                                        <TextBlock Text="{Binding PayloadType, Converter={StaticResource PayloadTypeToStringConverter}}"
                                                   FontSize="10" FontWeight="SemiBold" Opacity="0.7"/>
                                    </Border>
                                    <Button x:Name="CopyEntryButton"
                                            Click="CopyEntry_Click"
                                            Tag="{Binding}"
                                            Padding="6,3" MinHeight="0" MinWidth="0"
                                            ToolTipService.ToolTip="Copy this entry to clipboard"
                                            AutomationProperties.Name="Copy log entry">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                                            <TextBlock Text="Copy" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Formatted payload -->
                                <ScrollViewer Grid.Row="1" MaxHeight="300"
                                              HorizontalScrollMode="Auto"
                                              VerticalScrollMode="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding FormattedPayload}"
                                               FontFamily="Cascadia Code, Cascadia Mono, Consolas"
                                               FontSize="12" TextWrapping="Wrap"
                                               IsTextSelectionEnabled="True"/>
                                </ScrollViewer>
                            </Grid>
                        </Expander.Content>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Row 3: Action bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="ExportReportButton" Click="ExportReport_Click"
                    ToolTipService.ToolTip="Export a diagnostic report for support"
                    AutomationProperties.Name="Export diagnostic report">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
                    <TextBlock Text="Export Report"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding CopyAllCommand}"
                    ToolTipService.ToolTip="Copy all visible log entries to clipboard"
                    AutomationProperties.Name="Copy all entries">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                    <TextBlock Text="Copy All Visible"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ClearLogsCommand}"
                    ToolTipService.ToolTip="Clear the log buffer"
                    AutomationProperties.Name="Clear logs">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                    <TextBlock Text="Clear Logs"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding RefreshCommand}"
                    ToolTipService.ToolTip="Refresh log entries"
                    AutomationProperties.Name="Refresh logs">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- TeachingTip for copy confirmation -->
        <TeachingTip x:Name="CopyTip" Grid.Row="2"
                     Title="Copied!"
                     Subtitle="Log entry copied to clipboard"
                     IsLightDismissEnabled="True"
                     PreferredPlacement="Bottom"/>

        <!-- TeachingTip for export confirmation -->
        <TeachingTip x:Name="ExportTip" Grid.Row="2"
                     Title="Report Exported"
                     IsLightDismissEnabled="True"
                     PreferredPlacement="Bottom"/>
    </Grid>
</ContentDialog>
