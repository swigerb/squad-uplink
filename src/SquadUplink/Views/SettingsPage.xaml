<Page
    x:Class="SquadUplink.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Views"
    xmlns:vm="using:SquadUplink.ViewModels"
    xmlns:converters="using:SquadUplink.Converters">

    <Page.Resources>
        <converters:ColorToSolidColorBrushConverter x:Key="ColorToBrush" />
    </Page.Resources>

    <ScrollViewer Padding="24,16">
        <StackPanel Spacing="4" MaxWidth="800">

            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,16" />

            <!-- ═══ APPEARANCE ═══ -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      IsExpanded="True">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,8">
                        <FontIcon Glyph="&#xE790;" FontSize="16" />
                        <TextBlock Text="Appearance" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="16" Padding="4,8">
                    <!-- Theme Selector -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Theme" FontSize="13" />
                        <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                                  Width="260">
                            <ComboBoxItem Content="☀️  Fluent Light" />
                            <ComboBoxItem Content="🌙  Fluent Dark" />
                            <ComboBoxItem Content="🍏  Apple IIe" />
                            <ComboBoxItem Content="📺  Commodore 64" />
                            <ComboBoxItem Content="☢️  Pip-Boy" />
                            <ComboBoxItem Content="👽  MU-TH-UR 6000" />
                            <ComboBoxItem Content="🎮  W.O.P.R." />
                            <ComboBoxItem Content="💊  The Matrix" />
                            <ComboBoxItem Content="🖥️  Windows 95" />
                            <ComboBoxItem Content="🖖  LCARS" />
                            <ComboBoxItem Content="⭐  Star Wars" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Theme Preview -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Preview" FontSize="13" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="40" Height="28" CornerRadius="4"
                                    Background="{x:Bind ViewModel.PreviewAccentColor, Mode=OneWay, Converter={StaticResource ColorToBrush}}" />
                            <Border Width="40" Height="28" CornerRadius="4"
                                    Background="{x:Bind ViewModel.PreviewBackgroundColor, Mode=OneWay, Converter={StaticResource ColorToBrush}}" />
                            <Border Width="40" Height="28" CornerRadius="4"
                                    Background="{x:Bind ViewModel.PreviewSurfaceColor, Mode=OneWay, Converter={StaticResource ColorToBrush}}" />
                            <Border Width="40" Height="28" CornerRadius="4"
                                    Background="{x:Bind ViewModel.PreviewTextColor, Mode=OneWay, Converter={StaticResource ColorToBrush}}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- CRT Effects -->
                    <ToggleSwitch Header="CRT scan-line effects (retro themes)"
                                  IsOn="{x:Bind ViewModel.CrtEffectsEnabled, Mode=TwoWay}" />

                    <!-- Font Size -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Terminal font size" FontSize="13" />
                        <Slider Minimum="9" Maximum="24" StepFrequency="1"
                                Value="{x:Bind ViewModel.FontSize, Mode=TwoWay}"
                                Width="260" HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- ═══ SCANNING ═══ -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,8">
                        <FontIcon Glyph="&#xE773;" FontSize="16" />
                        <TextBlock Text="Scanning" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="16" Padding="4,8">
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="13">
                            <Run Text="Scan interval: " />
                            <Run Text="{x:Bind ViewModel.ScanIntervalSeconds, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" seconds" />
                        </TextBlock>
                        <Slider Minimum="1" Maximum="30" StepFrequency="1"
                                Value="{x:Bind ViewModel.ScanIntervalSeconds, Mode=TwoWay}"
                                Width="300" HorizontalAlignment="Left" />
                    </StackPanel>
                    <ToggleSwitch Header="Auto-scan on startup"
                                  IsOn="{x:Bind ViewModel.AutoScanOnStartup, Mode=TwoWay}" />
                </StackPanel>
            </Expander>

            <!-- ═══ LAUNCHING ═══ -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,8">
                        <FontIcon Glyph="&#xE895;" FontSize="16" />
                        <TextBlock Text="Launching" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="16" Padding="4,8">
                    <!-- Default working directory -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Default working directory" FontSize="13" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{x:Bind ViewModel.DefaultWorkingDirectory, Mode=TwoWay}"
                                     PlaceholderText="C:\Users\..."
                                     Width="400"
                                     FontFamily="Cascadia Mono,Consolas,monospace"
                                     FontSize="12" />
                            <Button Command="{x:Bind ViewModel.BrowseDirectoryCommand}"
                                    ToolTipService.ToolTip="Browse...">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Default model -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Default model override" FontSize="13" />
                        <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedModelIndex, Mode=TwoWay}"
                                  Width="260">
                            <ComboBoxItem Content="auto (detect)" />
                            <ComboBoxItem Content="claude-sonnet-4-20250514" />
                            <ComboBoxItem Content="claude-opus-4-20250514" />
                            <ComboBoxItem Content="gpt-4.1" />
                            <ComboBoxItem Content="o4-mini" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Always use remote -->
                    <ToggleSwitch Header="Always use --remote flag"
                                  IsOn="{x:Bind ViewModel.AlwaysUseRemote, Mode=TwoWay}" />
                </StackPanel>
            </Expander>

            <!-- ═══ SYSTEM TRAY ═══ -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,8">
                        <FontIcon Glyph="&#xE7C4;" FontSize="16" />
                        <TextBlock Text="System Tray" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="16" Padding="4,8">
                    <ToggleSwitch Header="Minimize to system tray"
                                  IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" />
                    <TextBlock Text="When enabled, closing the window keeps Squad Uplink running in the notification area. Right-click the tray icon for options."
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Expander>

            <!-- ═══ AUDIO ═══ -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,8">
                        <FontIcon Glyph="&#xE767;" FontSize="16" />
                        <TextBlock Text="Audio" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="16" Padding="4,8">
                    <ToggleSwitch Header="Enable audio feedback"
                                  IsOn="{x:Bind ViewModel.AudioEnabled, Mode=TwoWay}" />

                    <StackPanel Spacing="4">
                        <TextBlock FontSize="13">
                            <Run Text="Volume: " />
                            <Run Text="{x:Bind ViewModel.Volume, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text="%" />
                        </TextBlock>
                        <Slider Minimum="0" Maximum="100" StepFrequency="5"
                                Value="{x:Bind ViewModel.Volume, Mode=TwoWay}"
                                IsEnabled="{x:Bind ViewModel.AudioEnabled, Mode=OneWay}"
                                Width="260" HorizontalAlignment="Left" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Sound pack" FontSize="13" />
                        <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedSoundPackIndex, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.AudioEnabled, Mode=OneWay}"
                                  Width="260">
                            <ComboBoxItem Content="🔔  Fluent" />
                            <ComboBoxItem Content="🍏  Apple IIe" />
                            <ComboBoxItem Content="📺  C64" />
                            <ComboBoxItem Content="☢️  Pip-Boy" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- ═══ LOGS ═══ -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,8">
                        <FontIcon Glyph="&#xE9D9;" FontSize="16" />
                        <TextBlock Text="Logs" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="4,8">
                    <!-- Log level filter -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Minimum log level" FontSize="13" />
                        <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedLogLevelIndex, Mode=TwoWay}"
                                  Width="200">
                            <ComboBoxItem Content="Verbose" />
                            <ComboBoxItem Content="Debug" />
                            <ComboBoxItem Content="Information" />
                            <ComboBoxItem Content="Warning" />
                            <ComboBoxItem Content="Error" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Log actions -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.RefreshLogsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                <TextBlock Text="Refresh" />
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.ClearLogsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.ExportLogsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xEDE1;" FontSize="12" />
                                <TextBlock Text="Export" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Log viewer -->
                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="12" MaxHeight="300"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <ScrollViewer>
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock Text="{x:Bind}"
                                                   FontFamily="Cascadia Code,Consolas,monospace"
                                                   FontSize="11" IsTextSelectionEnabled="True"
                                                   TextWrapping="NoWrap"
                                                   Margin="0,1" />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Expander>

            <!-- ═══ ABOUT ═══ -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,8">
                        <FontIcon Glyph="&#xE946;" FontSize="16" />
                        <TextBlock Text="About" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="4,8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Squad Uplink" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Multi-session Copilot CLI Dashboard"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.VersionText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <HyperlinkButton Content="GitHub Repository"
                                         NavigateUri="https://github.com/swigerb/squad-uplink" />
                        <Button Command="{x:Bind ViewModel.CheckForUpdatesCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE895;" FontSize="12" />
                                <TextBlock Text="Check for Updates" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
