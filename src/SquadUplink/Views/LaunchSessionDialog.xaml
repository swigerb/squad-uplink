<ContentDialog
    x:Class="SquadUplink.Views.LaunchSessionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SquadUplink.Converters"
    Title="Launch New Session"
    PrimaryButtonText="Launch"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind IsValid, Mode=OneWay}">

    <ContentDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </ContentDialog.Resources>

    <StackPanel Spacing="16" MinWidth="420">

        <!-- Working Directory -->
        <StackPanel Spacing="4">
            <TextBlock Text="Working Directory" FontWeight="SemiBold" FontSize="13" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="WorkingDirectoryBox"
                         Text="{x:Bind WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="C:\repos\my-project" />
                <Button Grid.Column="1" Content="Browse..." Click="BrowseButton_Click"
                        VerticalAlignment="Bottom" />
            </Grid>
        </StackPanel>

        <!-- Recent Directories -->
        <StackPanel Spacing="4">
            <TextBlock Text="Recent Directories" FontWeight="SemiBold" FontSize="13" />
            <ComboBox x:Name="RecentDirsCombo"
                      ItemsSource="{x:Bind RecentDirectories}"
                      PlaceholderText="Select a recent directory..."
                      HorizontalAlignment="Stretch"
                      SelectionChanged="RecentDirsCombo_SelectionChanged" />
        </StackPanel>

        <!-- Initial Prompt -->
        <StackPanel Spacing="4">
            <TextBlock Text="Initial Prompt (optional)" FontWeight="SemiBold" FontSize="13" />
            <TextBox x:Name="InitialPromptBox"
                     Text="{x:Bind InitialPrompt, Mode=TwoWay}"
                     PlaceholderText="e.g., Fix the failing tests in auth module"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="60" MaxHeight="120" />
        </StackPanel>

        <!-- Model Override -->
        <StackPanel Spacing="4">
            <TextBlock Text="Model" FontWeight="SemiBold" FontSize="13" />
            <ComboBox x:Name="ModelCombo"
                      SelectedIndex="{x:Bind SelectedModelIndex, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Auto (default)" Tag="auto" />
                <ComboBoxItem Content="Sonnet" Tag="sonnet" />
                <ComboBoxItem Content="Opus" Tag="opus" />
                <ComboBoxItem Content="Haiku" Tag="haiku" />
            </ComboBox>
        </StackPanel>

        <!-- Remote Flag -->
        <CheckBox x:Name="RemoteCheckBox"
                  Content="Use --remote flag"
                  IsChecked="{x:Bind IsRemote, Mode=TwoWay}" />

        <!-- Validation Message -->
        <TextBlock x:Name="ValidationText"
                   Text="{x:Bind ValidationMessage, Mode=OneWay}"
                   Foreground="{StaticResource SquadErrorRedBrush}"
                   FontSize="12"
                   Visibility="{x:Bind HasValidationError, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
    </StackPanel>
</ContentDialog>
