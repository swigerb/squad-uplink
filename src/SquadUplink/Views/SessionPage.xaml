<Page
    x:Class="SquadUplink.Views.SessionPage"
    x:DefaultBindMode="OneWay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink.Views"
    xmlns:vm="using:SquadUplink.ViewModels"
    xmlns:converters="using:SquadUplink.Converters">

    <Page.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrush" />
        <converters:StatusToTextConverter x:Key="StatusToText" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="20,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Session Info Bar ═══ -->
        <Border Grid.Row="0" Style="{StaticResource CockpitPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16"
                            VerticalAlignment="Center">
                    <!-- Status Badge -->
                    <Border CornerRadius="4" Padding="10,4"
                            Background="{x:Bind ViewModel.CurrentStatus, Mode=OneWay, Converter={StaticResource StatusToBrush}}">
                        <TextBlock Text="{x:Bind ViewModel.CurrentStatus, Mode=OneWay, Converter={StaticResource StatusToText}}"
                                   FontSize="11" FontWeight="SemiBold" Foreground="White" />
                    </Border>

                    <!-- Repo name -->
                    <TextBlock Text="{x:Bind ViewModel.RepositoryName, Mode=OneWay}"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               FontSize="15" VerticalAlignment="Center" />

                    <Border Width="1" Height="20"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- PID -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE943;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ProcessIdText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" FontFamily="Cascadia Mono,Consolas,monospace" />
                    </StackPanel>

                    <Border Width="1" Height="20"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Working Directory -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8B7;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.WorkingDirectoryText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="350"
                                   FontSize="12" FontFamily="Cascadia Mono,Consolas,monospace" />
                    </StackPanel>

                    <Border Width="1" Height="20"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Age -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE823;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.SessionAge, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Command="{x:Bind ViewModel.StopCommand}"
                            ToolTipService.ToolTip="Stop Session"
                            Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE71A;" FontSize="12" Foreground="{StaticResource SquadErrorRedBrush}" />
                            <TextBlock Text="Stop" Foreground="{StaticResource SquadErrorRedBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.OpenInGitHubCommand}"
                            ToolTipService.ToolTip="Open in GitHub"
                            Visibility="{x:Bind ViewModel.HasGitHubUrl, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE71B;" FontSize="12" />
                            <TextBlock Text="GitHub" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.CopyTaskUrlCommand}"
                            ToolTipService.ToolTip="Copy Task URL"
                            Visibility="{x:Bind ViewModel.HasGitHubUrl, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Scrolling Terminal Output (RichTextBlock) ═══ -->
        <Border Grid.Row="1" CornerRadius="8" BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ScrollViewer x:Name="OutputScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          ViewChanged="OutputScrollViewer_ViewChanged"
                          Padding="12,8">
                <ItemsControl x:Name="OutputItemsControl"
                              ItemsSource="{x:Bind ViewModel.OutputLines, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       FontSize="12" TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True"
                                       Padding="0,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══ Key Session Info (always visible) ═══ -->
        <Border Grid.Row="2" Style="{StaticResource CockpitPanelStyle}" Padding="12,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Heartbeat -->
                <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.HeartbeatText, Mode=OneWay}"
                           FontSize="13" VerticalAlignment="Center" />

                <!-- Git Branch -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8AD;" FontSize="12"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.GitBranch, Mode=OneWay}"
                               FontSize="12" FontFamily="Cascadia Mono,Consolas,monospace"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Session Summary -->
                <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.SessionSummary, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />

                <!-- Agent Count Badge -->
                <Border Grid.Column="3" CornerRadius="10" Padding="8,2"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE716;" FontSize="11" />
                        <TextBlock FontSize="12">
                            <Run Text="{x:Bind ViewModel.AgentCount, Mode=OneWay}" />
                            <Run Text=" agents" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Detailed Session Telemetry ═══ -->
        <Expander Grid.Row="3" Header="Session Details"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  Margin="0,4,0,0"
                  IsExpanded="False">
            <Grid RowSpacing="8" Padding="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 1: Identity -->
                <Grid Grid.Row="0" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="SQUAD" FontSize="10" CharacterSpacing="80"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.SquadName, Mode=OneWay}" FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="UNIVERSE" FontSize="10" CharacterSpacing="80"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.SquadUniverse, Mode=OneWay}" FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="SESSION ID" FontSize="10" CharacterSpacing="80"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CopilotSessionId, Mode=OneWay}"
                                   FontSize="12" FontFamily="Cascadia Mono,Consolas,monospace" />
                    </StackPanel>
                </Grid>

                <!-- Row 2: Activity + Members -->
                <Grid Grid.Row="1" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="LAST ACTIVITY" FontSize="10" CharacterSpacing="80"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LastActivityText, Mode=OneWay}" FontSize="13" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="ERRORS" FontSize="10" CharacterSpacing="80"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ErrorLogSummary, Mode=OneWay}" FontSize="13"
                                   Foreground="{StaticResource SquadErrorRedBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="MEMBERS" FontSize="10" CharacterSpacing="80"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MemberRoster, Mode=OneWay}" FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Expander>
    </Grid>
</Page>
