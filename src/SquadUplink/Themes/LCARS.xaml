<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- LCARS — Library Computer Access/Retrieval System (Star Trek)   -->
    <!-- Background: #000000  Text: #FF9900  Accent: #CC99CC            -->
    <!-- Optimistic future, clean, organized, Starfleet precision       -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="LCARSBackground">#000000</Color>
    <Color x:Key="LCARSText">#FF9900</Color>
    <Color x:Key="LCARSAccent">#CC99CC</Color>
    <Color x:Key="LCARSDimText">#CC7700</Color>
    <Color x:Key="LCARSSurface">#0A0A14</Color>
    <Color x:Key="LCARSBorder">#CC99CC</Color>
    <Color x:Key="LCARSBlue">#9999FF</Color>
    <Color x:Key="LCARSPeach">#FF9966</Color>
    <Color x:Key="LCARSSalmon">#CC6666</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SquadAccentGreenBrush" Color="{StaticResource LCARSText}" />
    <SolidColorBrush x:Key="SquadAccentBlueBrush" Color="{StaticResource LCARSBlue}" />
    <SolidColorBrush x:Key="SquadWarningYellowBrush" Color="{StaticResource LCARSPeach}" />
    <SolidColorBrush x:Key="SquadErrorRedBrush" Color="{StaticResource LCARSSalmon}" />
    <SolidColorBrush x:Key="SquadNeutralGrayBrush" Color="{StaticResource LCARSDimText}" />

    <!-- Interactive brushes -->
    <SolidColorBrush x:Key="SquadInteractiveHoverBrush" Color="#22FF9900" />
    <SolidColorBrush x:Key="SquadInteractivePressedBrush" Color="#11FF9900" />

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource LCARSBackground}" />

    <!-- ═══ Status Badges — LCARS multi-color panels ═══ -->
    <Style x:Key="StatusBadgeRunning" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#FF9900" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
    <Style x:Key="StatusBadgeIdle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#9999FF" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
    <Style x:Key="StatusBadgeError" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#CC6666" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
    <Style x:Key="StatusBadgeCompleted" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#CC99CC" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <!-- Session Card — thick rounded asymmetric borders -->
    <Style x:Key="SessionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LCARSSurface}" />
        <Setter Property="CornerRadius" Value="16,4,4,16" />
        <Setter Property="Padding" Value="20,16,16,16" />
        <Setter Property="BorderBrush" Value="{StaticResource LCARSBorder}" />
        <Setter Property="BorderThickness" Value="4,1,1,1" />
    </Style>

    <Style x:Key="LaunchCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="16,4,4,16" />
        <Setter Property="Padding" Value="20,16,16,16" />
        <Setter Property="BorderBrush" Value="{StaticResource LCARSDimText}" />
        <Setter Property="BorderThickness" Value="4,1,1,1" />
    </Style>

    <Style x:Key="CockpitPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LCARSSurface}" />
        <Setter Property="CornerRadius" Value="16,4,4,16" />
        <Setter Property="Padding" Value="20,16,16,16" />
        <Setter Property="BorderBrush" Value="{StaticResource LCARSBorder}" />
        <Setter Property="BorderThickness" Value="4,1,1,1" />
    </Style>

    <!-- Typography — Segoe UI Bold (LCARS substitute) -->
    <Style x:Key="StatCounterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource LCARSText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource LCARSDimText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource LCARSAccent}" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource LCARSText}" />
    </Style>

    <!-- Gauge -->
    <Style x:Key="GaugeRingStyle" TargetType="ProgressRing">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="IsIndeterminate" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource LCARSText}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ═══ Typography Hierarchy — Starfleet precision ═══ -->
    <Style x:Key="SquadTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource LCARSText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource LCARSAccent}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource LCARSText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource LCARSDimText}" /></Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
