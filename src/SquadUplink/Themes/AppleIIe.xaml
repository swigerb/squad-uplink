<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Apple IIe — Green phosphor CRT theme                          -->
    <!-- Background: #000000  Text: #33FF33  Accent: #00CC00            -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="AppleIIeBackground">#000000</Color>
    <Color x:Key="AppleIIeText">#33FF33</Color>
    <Color x:Key="AppleIIeAccent">#00CC00</Color>
    <Color x:Key="AppleIIeDimText">#1A8C1A</Color>
    <Color x:Key="AppleIIeSurface">#0A140A</Color>
    <Color x:Key="AppleIIeBorder">#1A661A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SquadAccentGreenBrush" Color="{StaticResource AppleIIeAccent}" />
    <SolidColorBrush x:Key="SquadAccentBlueBrush" Color="{StaticResource AppleIIeAccent}" />
    <SolidColorBrush x:Key="SquadWarningYellowBrush" Color="#33CC33" />
    <SolidColorBrush x:Key="SquadErrorRedBrush" Color="#FF3333" />
    <SolidColorBrush x:Key="SquadNeutralGrayBrush" Color="{StaticResource AppleIIeDimText}" />

    <!-- Interactive brushes -->
    <SolidColorBrush x:Key="SquadInteractiveHoverBrush" Color="#2233FF33" />
    <SolidColorBrush x:Key="SquadInteractivePressedBrush" Color="#1133FF33" />

    <!-- Override system theme brushes for the retro look -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource AppleIIeBackground}" />

    <!-- ═══ Status Badges — monochrome green variants ═══ -->
    <Style x:Key="StatusBadgeRunning" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#33FF33" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeIdle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#1A8C1A" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeError" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#226622" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeCompleted" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#0D4D0D" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- Session Card — green phosphor border -->
    <Style x:Key="SessionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppleIIeSurface}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource AppleIIeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="LaunchCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource AppleIIeDimText}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="CockpitPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppleIIeSurface}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource AppleIIeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Typography — monospace green text -->
    <Style x:Key="StatCounterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource AppleIIeText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource AppleIIeDimText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource AppleIIeText}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource AppleIIeText}" />
    </Style>

    <!-- Gauge -->
    <Style x:Key="GaugeRingStyle" TargetType="ProgressRing">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="IsIndeterminate" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource AppleIIeAccent}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ═══ Typography Hierarchy — green phosphor ═══ -->
    <Style x:Key="SquadTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource AppleIIeText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource AppleIIeText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource AppleIIeText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource AppleIIeDimText}" /></Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
