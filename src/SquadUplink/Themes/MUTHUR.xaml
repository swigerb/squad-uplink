<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- MU-TH-UR 6000 — Nostromo shipboard AI terminal (Alien, 1979)  -->
    <!-- Background: #000000  Text: #33FF00  Accent: #00FF41            -->
    <!-- Cold, clinical, corporate-menacing                             -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="MUTHURBackground">#000000</Color>
    <Color x:Key="MUTHURText">#33FF00</Color>
    <Color x:Key="MUTHURAccent">#00FF41</Color>
    <Color x:Key="MUTHURDimText">#1A8C1A</Color>
    <Color x:Key="MUTHURSurface">#0A0F0A</Color>
    <Color x:Key="MUTHURBorder">#1A4D1A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SquadAccentGreenBrush" Color="{StaticResource MUTHURAccent}" />
    <SolidColorBrush x:Key="SquadAccentBlueBrush" Color="{StaticResource MUTHURAccent}" />
    <SolidColorBrush x:Key="SquadWarningYellowBrush" Color="#33CC00" />
    <SolidColorBrush x:Key="SquadErrorRedBrush" Color="#FF3333" />
    <SolidColorBrush x:Key="SquadNeutralGrayBrush" Color="{StaticResource MUTHURDimText}" />

    <!-- Interactive brushes -->
    <SolidColorBrush x:Key="SquadInteractiveHoverBrush" Color="#2200FF41" />
    <SolidColorBrush x:Key="SquadInteractivePressedBrush" Color="#1100FF41" />

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource MUTHURBackground}" />

    <!-- ═══ Status Badges — green intensity variants ═══ -->
    <Style x:Key="StatusBadgeRunning" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#00FF41" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeIdle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#1A8C1A" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeError" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#FF3333" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeCompleted" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#0D4D0D" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- Session Card — thin green border, clinical -->
    <Style x:Key="SessionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MUTHURSurface}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource MUTHURBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="LaunchCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource MUTHURDimText}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="CockpitPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MUTHURSurface}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource MUTHURBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Typography — monospace phosphor green -->
    <Style x:Key="StatCounterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource MUTHURText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource MUTHURDimText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource MUTHURAccent}" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource MUTHURText}" />
    </Style>

    <!-- Gauge -->
    <Style x:Key="GaugeRingStyle" TargetType="ProgressRing">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="IsIndeterminate" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource MUTHURAccent}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ═══ Typography Hierarchy — INTERFACE 2037 READY FOR INQUIRY ═══ -->
    <Style x:Key="SquadTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource MUTHURText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource MUTHURText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource MUTHURText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource MUTHURDimText}" /></Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
