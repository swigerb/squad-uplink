<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- The Matrix — Digital rain / God View aesthetic                  -->
    <!-- Background: #000000  Text: #00FF41  Accent: #008F11            -->
    <!-- Immersive, code-everywhere — I know kung fu                    -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="MatrixBackground">#000000</Color>
    <Color x:Key="MatrixText">#00FF41</Color>
    <Color x:Key="MatrixAccent">#008F11</Color>
    <Color x:Key="MatrixDimText">#003B00</Color>
    <Color x:Key="MatrixSurface">#001A00</Color>
    <Color x:Key="MatrixBorder">#004D00</Color>
    <Color x:Key="MatrixHighlight">#FFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SquadAccentGreenBrush" Color="{StaticResource MatrixText}" />
    <SolidColorBrush x:Key="SquadAccentBlueBrush" Color="{StaticResource MatrixAccent}" />
    <SolidColorBrush x:Key="SquadWarningYellowBrush" Color="#33CC33" />
    <SolidColorBrush x:Key="SquadErrorRedBrush" Color="#FF3333" />
    <SolidColorBrush x:Key="SquadNeutralGrayBrush" Color="{StaticResource MatrixAccent}" />

    <!-- Interactive brushes -->
    <SolidColorBrush x:Key="SquadInteractiveHoverBrush" Color="#2200FF41" />
    <SolidColorBrush x:Key="SquadInteractivePressedBrush" Color="#1100FF41" />

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource MatrixBackground}" />

    <!-- ═══ Status Badges — awakened / code variants ═══ -->
    <Style x:Key="StatusBadgeRunning" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#00FF41" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeIdle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#008F11" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeError" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#FF3333" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeCompleted" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#003B00" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- Session Card — almost-black green tint -->
    <Style x:Key="SessionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MatrixSurface}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource MatrixBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="LaunchCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource MatrixAccent}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="CockpitPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MatrixSurface}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource MatrixBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Typography — slightly smaller monospace for code density -->
    <Style x:Key="StatCounterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource MatrixText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource MatrixAccent}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource MatrixText}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource MatrixText}" />
    </Style>

    <!-- Gauge -->
    <Style x:Key="GaugeRingStyle" TargetType="ProgressRing">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="IsIndeterminate" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource MatrixText}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ═══ Typography Hierarchy — digital rain aesthetic ═══ -->
    <Style x:Key="SquadTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource MatrixText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource MatrixText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource MatrixText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource MatrixAccent}" /></Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
