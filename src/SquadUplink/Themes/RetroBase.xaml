<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- RetroBase — Shared styles for all retro themes                 -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Monospace font family for retro feel -->
    <FontFamily x:Key="RetroFontFamily">Cascadia Code,Cascadia Mono,Consolas,monospace</FontFamily>

    <!-- Scanline overlay (simulated with repeating gradients) -->
    <Style x:Key="ScanlineOverlayStyle" TargetType="Border">
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Opacity" Value="0.06" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,4" SpreadMethod="Repeat"
                                     MappingMode="Absolute">
                    <GradientStop Color="Transparent" Offset="0.0" />
                    <GradientStop Color="Transparent" Offset="0.5" />
                    <GradientStop Color="Black" Offset="0.5" />
                    <GradientStop Color="Black" Offset="1.0" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CRT glow effect for focused elements -->
    <Style x:Key="CrtGlowBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <!-- Retro text style -->
    <Style x:Key="RetroTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource RetroFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="40" />
    </Style>

    <!-- Retro panel style (overrides CockpitPanelStyle look in retro themes) -->
    <Style x:Key="RetroPanelStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Retro button style -->
    <Style x:Key="RetroButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource RetroFontFamily}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <!-- Retro header style -->
    <Style x:Key="RetroHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource RetroFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="60" />
    </Style>

</ResourceDictionary>
