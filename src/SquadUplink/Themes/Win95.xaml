<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Windows 95 — Classic chrome, 3D beveled, distinctly '90s       -->
    <!-- Background: #C0C0C0  Text: #000000  Accent: #000080            -->
    <!-- Nostalgic, chunky, Start menu era                              -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="Win95Background">#C0C0C0</Color>
    <Color x:Key="Win95Text">#000000</Color>
    <Color x:Key="Win95Accent">#000080</Color>
    <Color x:Key="Win95DimText">#808080</Color>
    <Color x:Key="Win95Surface">#FFFFFF</Color>
    <Color x:Key="Win95Border">#808080</Color>
    <Color x:Key="Win95Highlight">#000080</Color>
    <Color x:Key="Win95ButtonFace">#C0C0C0</Color>
    <Color x:Key="Win95ButtonHighlight">#FFFFFF</Color>
    <Color x:Key="Win95ButtonShadow">#808080</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SquadAccentGreenBrush" Color="#008000" />
    <SolidColorBrush x:Key="SquadAccentBlueBrush" Color="{StaticResource Win95Accent}" />
    <SolidColorBrush x:Key="SquadWarningYellowBrush" Color="#808000" />
    <SolidColorBrush x:Key="SquadErrorRedBrush" Color="#FF0000" />
    <SolidColorBrush x:Key="SquadNeutralGrayBrush" Color="{StaticResource Win95DimText}" />

    <!-- Interactive brushes -->
    <SolidColorBrush x:Key="SquadInteractiveHoverBrush" Color="#22000080" />
    <SolidColorBrush x:Key="SquadInteractivePressedBrush" Color="#11000080" />

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource Win95Background}" />

    <!-- ═══ Status Badges — classic Win95 colors ═══ -->
    <Style x:Key="StatusBadgeRunning" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#008000" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeIdle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#808000" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeError" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#FF0000" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeCompleted" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#808080" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- Session Card — 3D raised effect -->
    <Style x:Key="SessionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Win95Surface}" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource Win95ButtonShadow}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style x:Key="LaunchCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource Win95DimText}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style x:Key="CockpitPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Win95Surface}" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource Win95ButtonShadow}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Typography — Segoe UI (modern MS Sans Serif substitute) -->
    <Style x:Key="StatCounterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource Win95Text}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource Win95DimText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource Win95Accent}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Win95Text}" />
    </Style>

    <!-- Gauge -->
    <Style x:Key="GaugeRingStyle" TargetType="ProgressRing">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="IsIndeterminate" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource Win95Accent}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ═══ Typography Hierarchy — Classic Windows chrome ═══ -->
    <Style x:Key="SquadTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource Win95Accent}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource Win95Text}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource Win95Text}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource Win95DimText}" /></Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
