<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Star Wars — Imperial/Rebel hybrid command terminal              -->
    <!-- Background: #0A0A14  Text: #E0E0FF  Accent: #4488FF            -->
    <!-- Epic, cinematic — A long time ago in a galaxy far, far away... -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="SWBackground">#0A0A14</Color>
    <Color x:Key="SWText">#E0E0FF</Color>
    <Color x:Key="SWAccent">#4488FF</Color>
    <Color x:Key="SWDimText">#8888AA</Color>
    <Color x:Key="SWSurface">#0D1117</Color>
    <Color x:Key="SWBorder">#1A2A4A</Color>
    <Color x:Key="SWRebelOrange">#FF6B35</Color>
    <Color x:Key="SWImperialBlue">#88CCFF</Color>
    <Color x:Key="SWWarning">#FF4444</Color>
    <Color x:Key="SWSuccess">#44FF44</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SquadAccentGreenBrush" Color="{StaticResource SWSuccess}" />
    <SolidColorBrush x:Key="SquadAccentBlueBrush" Color="{StaticResource SWAccent}" />
    <SolidColorBrush x:Key="SquadWarningYellowBrush" Color="{StaticResource SWRebelOrange}" />
    <SolidColorBrush x:Key="SquadErrorRedBrush" Color="{StaticResource SWWarning}" />
    <SolidColorBrush x:Key="SquadNeutralGrayBrush" Color="{StaticResource SWDimText}" />

    <!-- Interactive brushes -->
    <SolidColorBrush x:Key="SquadInteractiveHoverBrush" Color="#224488FF" />
    <SolidColorBrush x:Key="SquadInteractivePressedBrush" Color="#114488FF" />

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource SWBackground}" />

    <!-- ═══ Status Badges — holographic/alert style ═══ -->
    <Style x:Key="StatusBadgeRunning" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#4488FF" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeIdle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#FF6B35" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeError" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#FF4444" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeCompleted" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#88CCFF" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- Session Card — Star Destroyer bridge aesthetic -->
    <Style x:Key="SessionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SWSurface}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource SWBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="LaunchCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource SWDimText}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="CockpitPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SWSurface}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource SWBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Typography — wider tracked headers, military Aurebesh feel -->
    <Style x:Key="StatCounterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource SWText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource SWDimText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource SWAccent}" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource SWText}" />
    </Style>

    <!-- Gauge -->
    <Style x:Key="GaugeRingStyle" TargetType="ProgressRing">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="IsIndeterminate" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource SWAccent}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ═══ Typography Hierarchy — cinematic holographic display ═══ -->
    <Style x:Key="SquadTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource SWText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource SWAccent}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource SWText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="CharacterSpacing" Value="40" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource SWDimText}" /></Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
