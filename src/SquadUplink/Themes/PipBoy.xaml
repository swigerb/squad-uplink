<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Pip-Boy — Amber/green Vault-Tec theme                         -->
    <!-- Background: #0A0A0A  Text: #FFB000  Accent: #FF8C00            -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="PipBoyBackground">#0A0A0A</Color>
    <Color x:Key="PipBoyText">#FFB000</Color>
    <Color x:Key="PipBoyAccent">#FF8C00</Color>
    <Color x:Key="PipBoyDimText">#996600</Color>
    <Color x:Key="PipBoySurface">#141410</Color>
    <Color x:Key="PipBoyBorder">#664400</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SquadAccentGreenBrush" Color="{StaticResource PipBoyAccent}" />
    <SolidColorBrush x:Key="SquadAccentBlueBrush" Color="{StaticResource PipBoyText}" />
    <SolidColorBrush x:Key="SquadWarningYellowBrush" Color="{StaticResource PipBoyText}" />
    <SolidColorBrush x:Key="SquadErrorRedBrush" Color="#FF4400" />
    <SolidColorBrush x:Key="SquadNeutralGrayBrush" Color="{StaticResource PipBoyDimText}" />

    <!-- Interactive brushes -->
    <SolidColorBrush x:Key="SquadInteractiveHoverBrush" Color="#22FFB000" />
    <SolidColorBrush x:Key="SquadInteractivePressedBrush" Color="#11FFB000" />

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource PipBoyBackground}" />

    <!-- ═══ Status Badges — amber variants ═══ -->
    <Style x:Key="StatusBadgeRunning" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#FFB000" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeIdle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="{StaticResource PipBoyDimText}" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeError" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#FF4400" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style x:Key="StatusBadgeCompleted" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#4D3300" /></Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- Session Card — gauge-inspired borders -->
    <Style x:Key="SessionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PipBoySurface}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource PipBoyBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="LaunchCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource PipBoyDimText}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="CockpitPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PipBoySurface}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{StaticResource PipBoyBorder}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Typography — Vault-Tec amber -->
    <Style x:Key="StatCounterTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource PipBoyText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource PipBoyDimText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="CharacterSpacing" Value="40" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <!-- Vault-Tec section header: all caps, tracked -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground" Value="{StaticResource PipBoyText}" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource PipBoyText}" />
    </Style>

    <!-- Gauge — amber ring style for Pip-Boy look -->
    <Style x:Key="GaugeRingStyle" TargetType="ProgressRing">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="IsIndeterminate" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource PipBoyAccent}" />
    </Style>

    <Style x:Key="SettingsSectionStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- ═══ Typography Hierarchy — Vault-Tec amber, all-caps tracked headers ═══ -->
    <Style x:Key="SquadTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource PipBoyText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource PipBoyText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource PipBoyText}" /></Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SquadCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Cascadia Code,Cascadia Mono,Consolas,monospace" />
        <Setter Property="CharacterSpacing" Value="40" />
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="{StaticResource PipBoyDimText}" /></Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
