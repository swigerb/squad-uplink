<Window
    x:Class="SquadUplink.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink"
    xmlns:views="using:SquadUplink.Views"
    xmlns:controls="using:SquadUplink.Controls"
    xmlns:converters="using:SquadUplink.Converters"
    xmlns:auto="using:Microsoft.UI.Xaml.Automation"
    Title="Squad Uplink">

    <Grid>
        <Grid.Resources>
            <converters:LevelToBrushConverter x:Key="PanelLevelBrush" />
            <converters:LevelToForegroundConverter x:Key="PanelLevelFg" />
            <converters:LogLevelToLineForegroundConverter x:Key="PanelLineFg" />
        </Grid.Resources>
        <Grid.KeyboardAccelerators>
            <!-- Ctrl+Tab: Next session -->
            <KeyboardAccelerator Key="Tab" Modifiers="Control"
                                 Invoked="NextSession_Invoked" />
            <!-- Ctrl+Shift+Tab: Previous session -->
            <KeyboardAccelerator Key="Tab" Modifiers="Control,Shift"
                                 Invoked="PreviousSession_Invoked" />
            <!-- Ctrl+1..9: Jump to session by index -->
            <KeyboardAccelerator Key="Number1" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number2" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number3" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number4" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number5" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number6" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number7" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number8" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number9" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <!-- Ctrl+N: Launch new session -->
            <KeyboardAccelerator Key="N" Modifiers="Control"
                                 Invoked="LaunchNewSession_Invoked" />
            <!-- Ctrl+W: Close current session -->
            <KeyboardAccelerator Key="W" Modifiers="Control"
                                 Invoked="CloseCurrentSession_Invoked" />
            <!-- F11: Toggle focused mode -->
            <KeyboardAccelerator Key="F11"
                                 Invoked="ToggleFocusedMode_Invoked" />
            <!-- Ctrl+Shift+U: Command Palette -->
            <KeyboardAccelerator Key="U" Modifiers="Control,Shift"
                                 Invoked="CommandPalette_Invoked" />
            <!-- Escape: Dismiss Command Palette -->
            <KeyboardAccelerator Key="Escape"
                                 Invoked="DismissOverlay_Invoked" />
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0"
              auto:AutomationProperties.Name="Application title bar">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="18"
                       Foreground="{StaticResource SquadAccentGreenBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0"
                       auto:AutomationProperties.AccessibilityView="Raw" />
            <TextBlock Grid.Column="1" Text="Squad Uplink"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       FontWeight="SemiBold" FontSize="13"
                       VerticalAlignment="Center"
                       auto:AutomationProperties.HeadingLevel="Level1" />
            <!-- Session count badge -->
            <Border Grid.Column="2" CornerRadius="8" MinWidth="20"
                    Padding="5,2" Margin="8,0,0,0"
                    VerticalAlignment="Center" HorizontalAlignment="Left"
                    Background="{StaticResource SquadAccentGreenBrush}"
                    auto:AutomationProperties.Name="Active session count">
                <TextBlock Text="{x:Bind SessionCountDisplay, Mode=OneWay}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center" />
            </Border>
            <TextBlock Grid.Column="4" x:Name="StatusText"
                       Text="{x:Bind StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Navigation + Content -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="NavView_SelectionChanged"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="True"
            OpenPaneLength="200">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sessions" Tag="Sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF0E2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="FooterSettingsItem" Content="Settings" Tag="SettingsFlyout"
                                    SelectsOnInvoked="False" Tapped="SettingsGear_Tapped">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="FooterStatusItem" SelectsOnInvoked="False" IsEnabled="False">
                    <NavigationViewItem.Icon>
                        <FontIcon x:Name="FooterStatusIcon" Glyph="&#xE895;"
                                  Foreground="{StaticResource SquadAccentGreenBrush}" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock x:Name="FooterStatusText" Text="Scanning..."
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Diagnostics Log Panel (expands upward from footer) -->
        <Border x:Name="DiagnosticsPanel" Grid.Row="1"
                VerticalAlignment="Bottom"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Height="300"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Panel toolbar -->
                <Grid Grid.Row="0" Padding="8,4"
                      Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Diagnostics"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="4,0,12,0" />

                    <!-- Log level dropdown (moved from footer) -->
                    <ComboBox x:Name="PanelLogLevelCombo" Grid.Column="1"
                              VerticalAlignment="Center" FontSize="11" MinWidth="100"
                              SelectedIndex="{x:Bind LogLevelIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="🔍 Debug" />
                        <ComboBoxItem Content="ℹ️ Info" />
                        <ComboBoxItem Content="🟡 Warning" />
                        <ComboBoxItem Content="🔴 Error" />
                    </ComboBox>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                        <Button Content="Full View" FontSize="11" Padding="8,3"
                                Click="OpenDiagnostics_Click"
                                ToolTipService.ToolTip="Open full diagnostics dialog" />
                        <Button FontSize="11" Padding="6,3"
                                Click="ClearPanelLogs_Click"
                                ToolTipService.ToolTip="Clear log entries">
                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Scrolling log entries -->
                <ListView x:Name="LogPanelList" Grid.Row="1"
                          Padding="4,2" SelectionMode="None"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,2" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Time}" FontSize="11"
                                           FontFamily="Cascadia Code,Cascadia Mono,Consolas"
                                           Opacity="0.5" VerticalAlignment="Center" />
                                <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="{Binding Level, Converter={StaticResource PanelLevelBrush}}">
                                    <TextBlock Text="{Binding LevelTag}" FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding Level, Converter={StaticResource PanelLevelFg}}" />
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding ShortMessage}"
                                           FontSize="11"
                                           FontFamily="Cascadia Code,Cascadia Mono,Consolas"
                                           TextTrimming="CharacterEllipsis" MaxLines="1"
                                           Foreground="{Binding Level, Converter={StaticResource PanelLineFg}}"
                                           VerticalAlignment="Center"
                                           ToolTipService.ToolTip="{Binding FullMessage}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Footer Status Bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Scanning indicator (animated dot) -->
                <Ellipse x:Name="StatusDot" Width="8" Height="8"
                         Fill="{StaticResource SquadAccentGreenBrush}"
                         Margin="0,0,8,0" VerticalAlignment="Center" />

                <!-- Status message -->
                <TextBlock Grid.Column="1" Text="{x:Bind StatusMessage, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />

                <!-- Session count pill -->
                <Border Grid.Column="2" CornerRadius="10" Padding="8,2"
                        Background="{StaticResource SquadAccentGreenBrush}" Margin="8,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind SessionCountDisplay, Mode=OneWay}"
                               FontSize="11" Foreground="White" FontWeight="SemiBold" />
                </Border>

                <!-- Diagnostics toggle (triangle expander) -->
                <ToggleButton x:Name="DiagToggle" Grid.Column="3"
                              VerticalAlignment="Center" Margin="8,0,0,0"
                              Padding="6,3" MinWidth="0" MinHeight="0"
                              Background="Transparent" BorderThickness="0"
                              Checked="DiagToggle_Checked" Unchecked="DiagToggle_Unchecked"
                              ToolTipService.ToolTip="Toggle diagnostics panel">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock x:Name="DiagToggleGlyph" Text="▶" FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="DiagErrorBadge" Text="" FontSize="10"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   Visibility="Collapsed" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- Command Palette Overlay (spans all rows) -->
        <controls:CommandPalette x:Name="CommandPaletteControl"
                                  Grid.Row="0" Grid.RowSpan="3" />

        <!-- Settings Flyout Panel (spans all rows) -->
        <controls:SettingsFlyoutPanel x:Name="SettingsFlyoutControl"
                                       Grid.Row="0" Grid.RowSpan="3" />

        <!-- CRT scan-line overlay (spans entire window) -->
        <controls:CrtEffectOverlay x:Name="CrtOverlay"
                                    Grid.RowSpan="3"
                                    IsEffectEnabled="{x:Bind IsCrtEnabled, Mode=OneWay}" />
    </Grid>
</Window>
