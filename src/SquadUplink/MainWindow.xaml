<Window
    x:Class="SquadUplink.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SquadUplink"
    xmlns:views="using:SquadUplink.Views"
    xmlns:auto="using:Microsoft.UI.Xaml.Automation"
    Title="Squad Uplink">

    <Grid>
        <Grid.KeyboardAccelerators>
            <!-- Ctrl+Tab: Next session -->
            <KeyboardAccelerator Key="Tab" Modifiers="Control"
                                 Invoked="NextSession_Invoked" />
            <!-- Ctrl+Shift+Tab: Previous session -->
            <KeyboardAccelerator Key="Tab" Modifiers="Control,Shift"
                                 Invoked="PreviousSession_Invoked" />
            <!-- Ctrl+1..9: Jump to session by index -->
            <KeyboardAccelerator Key="Number1" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number2" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number3" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number4" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number5" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number6" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number7" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number8" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <KeyboardAccelerator Key="Number9" Modifiers="Control"
                                 Invoked="JumpToSession_Invoked" />
            <!-- Ctrl+N: Launch new session -->
            <KeyboardAccelerator Key="N" Modifiers="Control"
                                 Invoked="LaunchNewSession_Invoked" />
            <!-- Ctrl+W: Close current session -->
            <KeyboardAccelerator Key="W" Modifiers="Control"
                                 Invoked="CloseCurrentSession_Invoked" />
            <!-- F11: Toggle focused mode -->
            <KeyboardAccelerator Key="F11"
                                 Invoked="ToggleFocusedMode_Invoked" />
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0"
              auto:AutomationProperties.Name="Application title bar">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="18"
                       Foreground="{StaticResource SquadAccentGreenBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0"
                       auto:AutomationProperties.AccessibilityView="Raw" />
            <TextBlock Grid.Column="1" Text="Squad Uplink"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       FontWeight="SemiBold" FontSize="13"
                       VerticalAlignment="Center"
                       auto:AutomationProperties.HeadingLevel="Level1" />
            <!-- Session count badge -->
            <Border Grid.Column="2" CornerRadius="8" MinWidth="20"
                    Padding="5,2" Margin="8,0,0,0"
                    VerticalAlignment="Center" HorizontalAlignment="Left"
                    Background="{StaticResource SquadAccentGreenBrush}"
                    auto:AutomationProperties.Name="Active session count">
                <TextBlock Text="{x:Bind SessionCountDisplay, Mode=OneWay}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center" />
            </Border>
            <TextBlock Grid.Column="4" x:Name="StatusText"
                       Text="{x:Bind StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Navigation + Content -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="NavView_SelectionChanged"
            IsSettingsVisible="True"
            IsPaneToggleButtonVisible="True"
            OpenPaneLength="200">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sessions" Tag="Sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF0E2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="FooterStatusItem" SelectsOnInvoked="False" IsEnabled="False">
                    <NavigationViewItem.Icon>
                        <FontIcon x:Name="FooterStatusIcon" Glyph="&#xE895;"
                                  Foreground="{StaticResource SquadAccentGreenBrush}" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <TextBlock x:Name="FooterStatusText" Text="Scanning..."
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </NavigationViewItem.Content>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
